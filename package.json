{
  "name": "crypto-quant-signal-mcp",
  "version": "1.9.0",
  "mcpName": "io.github.AlgoVaultFi/crypto-quant-signal-mcp",
  "description": "AI trading brain for crypto perps — composite signals, funding rate arb scanning, and market regime detection via MCP. Remote-first with x402 micropayments. Starting with Hyperliquid.",
  "main": "dist/index.js",
  "module": "src/index.ts",
  "bin": {
    "crypto-quant-signal-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:stdio": "TRANSPORT=stdio node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx src/scripts/seed-signals.ts",
    "backfill": "tsx src/scripts/backfill-outcomes.ts",
    "cron:signals": "tsx src/scripts/seed-signals.ts && tsx src/scripts/backfill-outcomes.ts",
    "cron:prod": "node dist/scripts/seed-signals.js && node dist/scripts/backfill-outcomes.js",
    "backtest": "npx tsx scripts/backtest.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "trading",
    "crypto",
    "signals",
    "hyperliquid",
    "funding-rate",
    "quant",
    "defi",
    "arbitrage",
    "technical-analysis",
    "model-context-protocol",
    "ai-agent",
    "x402"
  ],
  "author": "AlgoVault Labs",
  "license": "MIT",
  "dependencies": {
    "@buildersgarden/siwa": "^0.0.24",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@slicekit/erc8128": "^0.3.3",
    "@x402/core": "^2.9.0",
    "@x402/evm": "^2.9.0",
    "better-sqlite3": "^11.8.2",
    "binance": "^3.5.4",
    "bitget-api": "^3.1.6",
    "bybit-api": "^4.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "okx-api": "^3.1.3",
    "p-limit": "3.1.0",
    "pg": "^8.13.3",
    "redis": "^4.7.1",
    "stripe": "^22.0.1",
    "viem": "^2.47.12"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-viem": "^3.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.11.11",
    "hardhat": "^3.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "logo.png",
    "server.json",
    "smithery.yaml"
  ],
  "engines": {
    "node": ">=18"
  }
}
