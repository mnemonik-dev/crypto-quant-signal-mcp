# AlgoVault Caddyfile — canonical server config
# Live at /etc/caddy/Caddyfile on Hetzner (204.168.185.24)
# Applied via: systemctl reload caddy

api.algovault.com {
    handle /privacy {
        root * /var/www/algovault
        rewrite * /privacy.html
        file_server
    }
    handle /landing {
        root * /var/www/algovault
        rewrite * /index.html
        file_server
    }
    handle /logo.png {
        root * /var/www/algovault
        file_server
    }
    handle {
        reverse_proxy localhost:3000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
}

algovault.com {
    handle /track-record {
        reverse_proxy localhost:3000
    }
    # LANDING-REFERRAL-PAGE-W1 — apex /referral explainer + share page is
    # function-rendered by Express (renderReferralLandingPage). Placed BEFORE the
    # static catch-all so algovault.com/referral hits Express, not file_server
    # (same mechanism as /track-record above). Indexable; apex robots.txt allows /.
    handle /referral {
        reverse_proxy localhost:3000
    }
    # REFERRAL-WEB-FIX-W1 — the apex referee landing /join (function-rendered by
    # renderJoinPage) every web share link points to. Placed BEFORE the static
    # catch-all (same mechanism as /track-record); makes algovault.com/join?ref= 200.
    handle /join {
        reverse_proxy localhost:3000
    }
    # LANDING-REFERRAL-PAGE-W1 (fix) — the public referral-terms page is function-
    # rendered (api-only by default); proxy it onto the apex too so the /referral
    # page's relative "referral terms" link + any externally-shared algovault.com/
    # referral-terms URL resolve (was a 404 on the apex). Content/legal page → apex.
    handle /referral-terms {
        reverse_proxy localhost:3000
    }
    handle /api/performance-public {
        reverse_proxy localhost:3000
    }
    # REFERRAL-FREE-KEY-SIGNUP-W1 — the apex /referral free-account form POSTs here.
    # Scoped to /api/signup-email ONLY (NOT a blanket /api/* on the apex) so the POST
    # is same-origin (no CORS widening; CORS still allows api.algovault.com only).
    handle /api/signup-email {
        reverse_proxy localhost:3000
    }
    handle /api/merkle-batches {
        reverse_proxy localhost:3000
    }
    # OPS-CADDY-ROUTE-PARITY-W1 (2026-06-18): track-record-proxy.js hydrates the ERC-8004
    # agent-id badge via a RELATIVE fetch of /api/erc-8004-reputation; without this handle
    # it fell through to the static file_server below and 404'd on algovault.com (the span
    # silently used its static fallback). Allowlist update was missed when the endpoint
    # shipped (ERC-8004-W1) — same class as /api/recent-calls above. Guarded going forward
    # by tests/unit/caddy-route-parity.test.mjs.
    handle /api/erc-8004-reputation {
        reverse_proxy localhost:3000
    }
    handle /api/verify-signal {
        reverse_proxy localhost:3000
    }
    handle /api/confidence-bands-public {
        reverse_proxy localhost:3000
    }
    handle /api/verify-sample-ids {
        reverse_proxy localhost:3000
    }
    # DESIGN-W7 fix-forward 2026-05-11 — landing-page hero hydration
    # (MOST RECENT CALL + CALL STREAM) fetches /api/recent-calls?limit=N
    # via relative URL; without this handle the request falls through to
    # the static file_server below and 404s. Endpoint was added in
    # LANDING-LIVE-CALL-TICKER-W1 (2026-05-09); allowlist update missed.
    handle /api/recent-calls {
        reverse_proxy localhost:3000
    }
    # INTEGRATIONS-W1 C6 — proxy integration tutorial mirrors to Express.
    # Allowlisted in src/index.ts. Placed BEFORE the static catch-all so
    # /docs/integrations/* never falls through to a 404 from file_server.
    handle /docs/integrations/* {
        reverse_proxy localhost:3000
    }
    # WEBSITE-REFRESH-W1 C4 — dedicated /skills page (pre-rendered HTML
    # served from in-image landing/skills.html via Express). Placed BEFORE
    # the static catch-all so /skills routes hit Express, not file_server.
    handle /skills {
        reverse_proxy localhost:3000
    }
    # WEBSITE-REFRESH-CLEANUP-W1 R4 — manifest-driven /integrations index page
    # (pre-rendered HTML served from in-image landing/integrations.html via
    # Express). Placed BEFORE the static catch-all so /integrations routes hit
    # Express, not file_server.
    handle /integrations {
        reverse_proxy localhost:3000
    }
    # DOCS-INTEGRATION-H2-W1 (2026-05-18) — per-slug tutorial pages moved from
    # /docs/integrations/<slug> to /integrations/<slug> (4 exchanges +
    # 4 frameworks). Express serves the canonical path here. The old
    # /docs/integrations/* handler above (proxied to Express) still receives
    # requests and returns a 301 redirect to the new path for backward
    # compatibility with any pre-2026-05-18 external link or indexed result.
    handle /integrations/* {
        reverse_proxy localhost:3000
    }
    handle {
        root * /var/www/algovault
        try_files {path} {path}.html {path}/index.html

        # Short-cache + must-revalidate for all static landing pages so
        # browser stale-cache bugs cannot recur (2026-04-19 verify incident).
        # 60s max-age = browsers revalidate within 1 minute of a deploy.
        header Cache-Control "public, max-age=60, must-revalidate"

        file_server
    }
}
