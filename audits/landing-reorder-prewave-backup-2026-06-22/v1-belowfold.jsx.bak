// AlgoVault landing — below-the-fold sections (Core capabilities · When to use · vs raw exchange APIs)
// Carries hero design tokens: dark bg, mint accent, Inter Tight + Inter + JetBrains Mono.
// Card shapes (1px solid var(--line) on oklch(0.18 .014 265 / 0.5), 14px radius) match the hero feed/track-record cards.

/* ---------- Icons ---------- */
const BFIcon = {
  TradeCall: ({ size = 28 }) => (
    <svg width={size} height={size} viewBox="0 0 32 32" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round">
      <rect x="4" y="20" width="4" height="8" rx="1" />
      <rect x="11" y="14" width="4" height="14" rx="1" />
      <rect x="18" y="9" width="4" height="19" rx="1" />
      <path d="M5 11l8 4 5-3 7 4" stroke="var(--accent, oklch(0.86 0.16 165))" strokeWidth="1.5" />
      <path d="M22 6h4v4" stroke="var(--accent, oklch(0.86 0.16 165))" />
    </svg>
  ),
  Regime: ({ size = 28 }) => (
    <svg width={size} height={size} viewBox="0 0 32 32" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round">
      <path d="M3 18 Q 8 8 13 18 T 23 18 T 30 14" />
      <path d="M3 24 Q 8 14 13 24 T 23 24 T 30 20" stroke="var(--accent, oklch(0.86 0.16 165))" opacity="0.7" />
      <circle cx="13" cy="18" r="1.5" fill="var(--accent, oklch(0.86 0.16 165))" stroke="none" />
    </svg>
  ),
  Arb: ({ size = 28 }) => (
    <svg width={size} height={size} viewBox="0 0 32 32" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round">
      <path d="M5 11h18" />
      <path d="M19 7l4 4-4 4" />
      <path d="M27 21H9" stroke="var(--accent, oklch(0.86 0.16 165))" />
      <path d="M13 25l-4-4 4-4" stroke="var(--accent, oklch(0.86 0.16 165))" />
    </svg>
  ),
  Chain: ({ size = 28 }) => (
    <svg width={size} height={size} viewBox="0 0 32 32" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round">
      <path d="M13 19l-3 3a4.5 4.5 0 0 1-6.4-6.4l4-4a4.5 4.5 0 0 1 6.4 0" />
      <path d="M19 13l3-3a4.5 4.5 0 0 1 6.4 6.4l-4 4a4.5 4.5 0 0 1-6.4 0" stroke="var(--accent, oklch(0.86 0.16 165))" />
      <path d="M12 20l8-8" strokeDasharray="2 3" opacity="0.6" />
    </svg>
  ),
  Agent: ({ size = 28 }) => (
    <svg width={size} height={size} viewBox="0 0 32 32" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round">
      <rect x="6" y="11" width="20" height="14" rx="3" />
      <circle cx="12" cy="18" r="1.6" fill="var(--accent, oklch(0.86 0.16 165))" stroke="none" />
      <circle cx="20" cy="18" r="1.6" fill="var(--accent, oklch(0.86 0.16 165))" stroke="none" />
      <path d="M16 6v5" />
      <circle cx="16" cy="5" r="1.4" fill="currentColor" stroke="none" />
      <path d="M11 25l-1 4M21 25l1 4" />
    </svg>
  ),
  Layers: ({ size = 28 }) => (
    <svg width={size} height={size} viewBox="0 0 32 32" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinejoin="round">
      <path d="M16 4 L28 10 L16 16 L4 10 Z" stroke="var(--accent, oklch(0.86 0.16 165))" />
      <path d="M4 16 L16 22 L28 16" />
      <path d="M4 22 L16 28 L28 22" opacity="0.6" />
    </svg>
  ),
  Verify: ({ size = 28 }) => (
    <svg width={size} height={size} viewBox="0 0 32 32" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinejoin="round" strokeLinecap="round">
      <path d="M16 4 L26 8 V17 C26 22 22 26 16 28 C10 26 6 22 6 17 V8 Z" />
      <path d="M11 16l4 4 7-8" stroke="var(--accent, oklch(0.86 0.16 165))" strokeWidth="2" />
    </svg>
  ),
  // LANDING-HOW-IT-WORKS-W1 (2026-05-13): self-tuning model — recursive trending-up curve
  // with a tuning-dial accent. Matches the BFIcon visual language (28px viewBox 32x32,
  // currentColor + one mint accent stroke, rounded caps/joins).
  Model: ({ size = 28 }) => (
    <svg width={size} height={size} viewBox="0 0 32 32" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round">
      <path d="M4 23 L10 17 L14 20 L20 12 L26 16" />
      <circle cx="20" cy="12" r="1.6" fill="var(--accent, oklch(0.86 0.16 165))" stroke="none" />
      <path d="M26 9 a 5 5 0 1 1 -0.01 0" stroke="var(--accent, oklch(0.86 0.16 165))" />
      <path d="M26 5 v 3" stroke="var(--accent, oklch(0.86 0.16 165))" />
    </svg>
  ),
};

/* ---------- Section primitives ---------- */
function BFEyebrow({ children }) {
  return (
    <div style={{ display: 'inline-flex', alignItems: 'center', gap: 10, marginBottom: 18,
      fontFamily: 'var(--font-mono)', fontSize: 11, color: 'var(--fg-3)',
      letterSpacing: '0.14em', textTransform: 'uppercase' }}>
      <span style={{ width: 5, height: 5, borderRadius: '50%', background: 'var(--accent, var(--mint))',
        boxShadow: '0 0 8px var(--accent, var(--mint))' }} />
      {children}
    </div>
  );
}

function BFH2({ children, mobile }) {
  return (
    <h2 style={{
      fontFamily: 'var(--font-display)',
      fontSize: mobile ? 30 : 48,
      lineHeight: 1.05,
      letterSpacing: '-0.022em',
      fontWeight: 500,
      margin: 0,
      textWrap: 'balance',
      color: 'var(--fg)',
    }}>{children}</h2>
  );
}

function BFSection({ id, children, mobile, dim = false }) {
  return (
    <section id={id} style={{
      position: 'relative',
      padding: mobile ? '64px 22px' : '120px 80px',
      borderTop: '1px solid var(--line)',
      background: dim
        ? 'linear-gradient(180deg, transparent, oklch(0.155 0.012 265 / 0.7) 30%, oklch(0.155 0.012 265 / 0.7) 70%, transparent)'
        : 'transparent',
    }}>{children}</section>
  );
}

/* ---------- Section 1: Core capabilities ---------- */
function CoreCapabilities({ mobile = false }) {
  const items = [
    { Icon: BFIcon.TradeCall, name: 'Composite trade calls.', detail: 'BUY / SELL / HOLD with confidence.', tool: 'get_trade_call' },
    { Icon: BFIcon.Regime, name: 'Market regime classification.', detail: 'Trending / ranging / volatile.', tool: 'get_market_regime' },
    { Icon: BFIcon.Arb, name: 'Cross-venue funding arbitrage.', detail: 'Top spreads across Hyperliquid, Binance, Bybit.', tool: 'scan_funding_arb' },
    // LANDING-HOW-IT-WORKS-W1 (2026-05-13): replaced 'On-chain track record' card with substrate-tier
    // 'Self-tuning ML model' card linking to /how-it-works. On-chain claim survives on landing/index.html
    // via M1 hero ("Merkle-verified on Base L2") + Verify Any Call card + Track Record proxy section.
    { Icon: BFIcon.Model, name: 'Self-tuning ML model.', detail: 'Gets sharper with every call.', tool: 'How it works', toolHref: '/how-it-works' },
  ];
  return (
    <BFSection id="core-capabilities" mobile={mobile}>
      <BFEyebrow>· capabilities</BFEyebrow>
      <BFH2 mobile={mobile}>Core capabilities</BFH2>
      <p style={{ fontSize: mobile ? 15 : 17, color: 'var(--fg-2)', maxWidth: 600,
        margin: mobile ? '14px 0 32px' : '20px 0 56px', lineHeight: 1.6 }}>
        Four MCP tools your agent can call directly. Each returns a single, structured verdict — not raw indicators.
      </p>
      <div style={{
        display: 'grid',
        gridTemplateColumns: mobile ? '1fr' : '1fr 1fr',
        gap: mobile ? 14 : 22,
      }}>
        {items.map((it, i) => (
          <article key={i} style={{
            position: 'relative',
            padding: mobile ? '22px 20px' : '32px 32px 28px',
            border: '1px solid var(--line)',
            borderRadius: 14,
            background: 'oklch(0.18 0.014 265 / 0.55)',
            display: 'flex', flexDirection: 'column', gap: mobile ? 14 : 20,
            minHeight: mobile ? 'auto' : 220,
          }}>
            <div style={{
              width: mobile ? 42 : 52, height: mobile ? 42 : 52,
              borderRadius: 11,
              border: '1px solid var(--line-2)',
              background: 'oklch(0.22 0.012 265 / 0.7)',
              display: 'grid', placeItems: 'center',
              color: 'var(--fg)',
            }}>
              <it.Icon size={mobile ? 22 : 28} />
            </div>
            <div>
              <div style={{ fontFamily: 'var(--font-display)', fontSize: mobile ? 19 : 23,
                fontWeight: 500, letterSpacing: '-0.012em', marginBottom: 6, color: 'var(--fg)' }}>
                {it.name}
              </div>
              <div style={{ color: 'var(--fg-2)', fontSize: mobile ? 14 : 15.5, lineHeight: 1.55 }}>
                {it.detail}
              </div>
            </div>
            <div style={{ marginTop: 'auto', paddingTop: mobile ? 4 : 8 }}>
              {it.toolHref ? (
                <a href={it.toolHref} style={{
                  display: 'inline-flex', alignItems: 'center', gap: 6,
                  padding: '6px 11px',
                  border: '1px solid var(--line)',
                  borderRadius: 999,
                  background: 'oklch(0.13 0.012 265 / 0.7)',
                  fontFamily: 'var(--font-mono)',
                  fontSize: 11.5,
                  color: 'var(--accent, var(--mint))',
                  textDecoration: 'none',
                }}>
                  <span style={{ color: 'var(--fg-4)' }}>›</span>
                  {it.tool}
                </a>
              ) : (
                <span style={{
                  display: 'inline-flex', alignItems: 'center', gap: 6,
                  padding: '6px 11px',
                  border: '1px solid var(--line)',
                  borderRadius: 999,
                  background: 'oklch(0.13 0.012 265 / 0.7)',
                  fontFamily: 'var(--font-mono)',
                  fontSize: 11.5,
                  color: 'var(--accent, var(--mint))',
                }}>
                  <span style={{ color: 'var(--fg-4)' }}>›</span>
                  {it.tool}
                </span>
              )}
            </div>
          </article>
        ))}
      </div>
    </BFSection>
  );
}

/* ---------- Section 2: When to use AlgoVault ---------- */
function WhenToUse({ mobile = false }) {
  const items = [
    { Icon: BFIcon.Agent, headline: 'Building an AI agent that trades crypto perps across multiple venues.' },
    { Icon: BFIcon.Layers, headline: 'Skipping 8-indicator parsing for one composite verdict per call.' },
    { Icon: BFIcon.Verify, headline: 'Verifying signal performance on-chain before integrating.' },
  ];
  return (
    <BFSection id="when-to-use" mobile={mobile} dim>
      <BFEyebrow>· fit</BFEyebrow>
      <BFH2 mobile={mobile}>When to use AlgoVault</BFH2>
      <div style={{
        display: 'grid',
        gridTemplateColumns: mobile ? '1fr' : 'repeat(3, 1fr)',
        gap: mobile ? 14 : 22,
        marginTop: mobile ? 32 : 56,
      }}>
        {items.map((it, i) => (
          <article key={i} style={{
            position: 'relative',
            padding: mobile ? '24px 22px' : '36px 32px 38px',
            border: '1px solid var(--line)',
            borderRadius: 14,
            background: 'oklch(0.18 0.014 265 / 0.55)',
            minHeight: mobile ? 'auto' : 240,
            display: 'flex', flexDirection: 'column',
          }}>
            <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between',
              marginBottom: mobile ? 16 : 24 }}>
              <span style={{
                fontFamily: 'var(--font-mono)', fontSize: 11, color: 'var(--accent, var(--mint))',
                letterSpacing: '0.16em',
              }}>0{i + 1}</span>
              <div style={{
                width: mobile ? 38 : 48, height: mobile ? 38 : 48,
                borderRadius: 10,
                border: '1px solid var(--line-2)',
                background: 'oklch(0.22 0.012 265 / 0.7)',
                display: 'grid', placeItems: 'center',
                color: 'var(--fg)',
              }}>
                <it.Icon size={mobile ? 22 : 26} />
              </div>
            </div>
            <p style={{
              fontFamily: 'var(--font-display)',
              fontSize: mobile ? 17 : 20,
              lineHeight: 1.32,
              letterSpacing: '-0.012em',
              fontWeight: 500,
              margin: 0,
              color: 'var(--fg)',
              textWrap: 'balance',
            }}>
              {it.headline}
            </p>
          </article>
        ))}
      </div>
    </BFSection>
  );
}

/* ---------- Section 3: vs raw exchange APIs ---------- */
function VsRawAPIs({ mobile = false }) {
  const cols = [
    {
      name: 'Exchange APIs',
      sub: 'Raw venue endpoints',
      output: '8 raw indicators per call',
      builtFor: 'Programmatic raw data — your agent interprets each indicator',
      integration: 'N adapter integrations · per-venue auth · per-venue ratelimits',
      muted: true,
    },
    {
      name: 'AlgoVault',
      sub: 'MCP brain layer',
      output: 'One verdict per call · {call, confidence, regime, factors}',
      builtFor: 'AI agents reading verdicts',
      integration: '5 venues unified behind one MCP · skip N adapter integrations',
      highlight: true,
    },
    {
      name: 'TradingView · Coinglass',
      sub: 'Visual analytics',
      output: 'Charts + tables for humans',
      builtFor: 'Humans reading charts',
      integration: 'Web/app dashboards · screenshot in, decision out',
      muted: true,
    },
  ];
  const rows = [
    { label: 'Output per call', key: 'output' },
    { label: 'Built for', key: 'builtFor' },
    { label: 'Integration', key: 'integration' },
  ];

  if (mobile) {
    return (
      <BFSection id="vs-raw-exchange-apis" mobile>
        <BFEyebrow>· compare</BFEyebrow>
        <BFH2 mobile>Why not just use exchange APIs?</BFH2>
        <p style={{ fontSize: 14.5, color: 'var(--fg-2)', maxWidth: 320,
          margin: '14px 0 28px', lineHeight: 1.55 }}>
          Three places to source signal for an agent. Only one is built for verdicts.
        </p>
        <div style={{ display: 'flex', flexDirection: 'column', gap: 12 }}>
          {cols.map((c, i) => (
            <article key={i} style={{
              padding: '22px 20px',
              border: c.highlight ? '1px solid var(--accent, var(--mint))' : '1px solid var(--line)',
              borderRadius: 14,
              background: c.highlight
                ? 'linear-gradient(180deg, oklch(0.32 0.08 170 / 0.28), oklch(0.18 0.014 265 / 0.6))'
                : 'oklch(0.18 0.014 265 / 0.5)',
              boxShadow: c.highlight
                ? '0 0 0 1px oklch(0.86 0.16 165 / 0.12), 0 18px 40px -22px oklch(0.86 0.16 165 / 0.4)'
                : 'none',
            }}>
              <div style={{ display: 'flex', alignItems: 'baseline', justifyContent: 'space-between',
                marginBottom: 14, gap: 12 }}>
                <span style={{
                  fontFamily: 'var(--font-display)', fontSize: 19, fontWeight: 500,
                  letterSpacing: '-0.012em',
                  color: c.highlight ? 'var(--accent, var(--mint))' : 'var(--fg)',
                }}>
                  {c.name}
                </span>
                <span className="placeholder-cap" style={{ fontSize: 9.5, textAlign: 'right' }}>{c.sub}</span>
              </div>
              {rows.map((r) => (
                <div key={r.key} style={{ paddingTop: 10, borderTop: '1px solid var(--line)' }}>
                  <div className="placeholder-cap" style={{ fontSize: 9.5, marginBottom: 4 }}>{r.label}</div>
                  <div style={{
                    fontSize: 13.5, color: c.muted ? 'var(--fg-2)' : 'var(--fg)',
                    lineHeight: 1.5, marginBottom: 12,
                    fontWeight: c.highlight ? 500 : 400,
                  }}>
                    {c[r.key]}
                  </div>
                </div>
              ))}
            </article>
          ))}
        </div>
        <p style={{ marginTop: 22, fontSize: 13, color: 'var(--fg-3)' }}>
          See <a href="/skills" style={{ color: 'var(--accent, var(--mint))', textDecoration: 'none' }}>/skills</a>
          {' '}+ <a href="/docs" style={{ color: 'var(--accent, var(--mint))', textDecoration: 'none' }}>/docs</a>.
        </p>
      </BFSection>
    );
  }

  return (
    <BFSection id="vs-raw-exchange-apis">
      <BFEyebrow>· compare</BFEyebrow>
      <BFH2>Why not just use exchange APIs?</BFH2>
      <p style={{ fontSize: 17, color: 'var(--fg-2)', maxWidth: 600, margin: '20px 0 56px', lineHeight: 1.6 }}>
        Three places to source signal for an agent. Only one is built for verdicts.
      </p>
      <div style={{
        display: 'grid',
        gridTemplateColumns: '200px 1fr 1.05fr 1fr',
        border: '1px solid var(--line)',
        borderRadius: 16,
        overflow: 'hidden',
        background: 'oklch(0.16 0.012 265 / 0.7)',
      }}>
        {/* Header row */}
        <div style={{ padding: '24px 24px 18px' }} />
        {cols.map((c, i) => (
          <div key={i} style={{
            padding: '24px 26px 20px',
            borderLeft: '1px solid var(--line)',
            background: c.highlight
              ? 'linear-gradient(180deg, oklch(0.32 0.08 170 / 0.34), oklch(0.18 0.014 265 / 0.45))'
              : 'transparent',
            position: 'relative',
          }}>
            {c.highlight && (
              <div style={{ position: 'absolute', top: 0, left: 0, right: 0, height: 2,
                background: 'var(--accent, var(--mint))',
                boxShadow: '0 0 14px var(--accent, var(--mint))' }} />
            )}
            <div style={{
              fontFamily: 'var(--font-display)', fontSize: 24, fontWeight: 500, letterSpacing: '-0.014em',
              color: c.highlight ? 'var(--accent, var(--mint))' : 'var(--fg)',
              marginBottom: 5,
            }}>{c.name}</div>
            <div className="placeholder-cap" style={{ fontSize: 10 }}>{c.sub}</div>
          </div>
        ))}

        {rows.map((r) => (
          <React.Fragment key={r.key}>
            <div style={{
              padding: '24px 24px',
              borderTop: '1px solid var(--line)',
              fontFamily: 'var(--font-mono)', fontSize: 11.5,
              color: 'var(--fg-3)', letterSpacing: '0.06em',
              textTransform: 'uppercase',
              display: 'flex', alignItems: 'center',
            }}>{r.label}</div>
            {cols.map((c, ci) => (
              <div key={ci} style={{
                padding: '24px 26px',
                borderTop: '1px solid var(--line)',
                borderLeft: '1px solid var(--line)',
                background: c.highlight
                  ? 'oklch(0.22 0.05 170 / 0.18)'
                  : 'transparent',
                fontSize: 15.5,
                lineHeight: 1.55,
                color: c.muted ? 'var(--fg-2)' : 'var(--fg)',
                fontWeight: c.highlight ? 500 : 400,
              }}>
                {c[r.key]}
              </div>
            ))}
          </React.Fragment>
        ))}
      </div>
      <p style={{ marginTop: 28, fontSize: 14.5, color: 'var(--fg-3)' }}>
        See <a href="/skills" style={{ color: 'var(--accent, var(--mint))', textDecoration: 'none' }}>/skills</a>
        {' '}+ <a href="/docs" style={{ color: 'var(--accent, var(--mint))', textDecoration: 'none' }}>/docs</a>.
      </p>
    </BFSection>
  );
}

/* ---------- Composed below-fold artboard ---------- */
function AlgoVaultBelowFold({ mobile = false }) {
  return (
    <div className="artboard" style={{
      width: mobile ? 375 : 1440,
      padding: 0,
      background: 'oklch(0.13 0.012 265)',
      color: 'oklch(0.97 0.005 265)',
      position: 'relative',
      overflow: 'hidden',
    }}>
      <div className="bg-grid" />
      <div className="bg-noise" />
      <div style={{ position: 'relative', zIndex: 1 }}>
        <CoreCapabilities mobile={mobile} />
        <WhenToUse mobile={mobile} />
        <VsRawAPIs mobile={mobile} />
      </div>
    </div>
  );
}

Object.assign(window, {
  AlgoVaultBelowFold,
  CoreCapabilities, WhenToUse, VsRawAPIs,
});
