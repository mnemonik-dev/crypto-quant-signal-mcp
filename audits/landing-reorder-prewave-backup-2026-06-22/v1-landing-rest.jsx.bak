            flex: 1
          }}>
              {c.code}
            </pre>
            <div style={{ fontSize: 12, color: 'var(--fg-3)', lineHeight: 1.5 }}>
              {c.foot}
            </div>
          </article>
        )}
      </div>
      <div style={{ marginTop: mobile ? 22 : 28, display: 'flex', gap: 10, flexWrap: 'wrap' }}>
        {['npm', 'GitHub', 'MCP Registry'].map((b, i) =>
        <a key={i} href={`#${b}`} style={{
          padding: '6px 12px', borderRadius: 999, border: '1px solid var(--line)',
          fontFamily: 'var(--font-mono)', fontSize: 11.5, color: 'var(--fg-2)',
          textDecoration: 'none', background: 'oklch(0.2 0.012 265 / 0.6)',
          display: 'inline-flex', alignItems: 'center', gap: 6
        }}>
