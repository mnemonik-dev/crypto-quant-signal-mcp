/* ================================================================
   9. FAQ — accordion
   ================================================================ */
function FAQItem({ q, a, defaultOpen = false, mobile }) {
  const [open, setOpen] = React.useState(defaultOpen);
  return (
    <article style={{
      border: open ? '1px solid var(--accent, var(--mint))' : '1px solid var(--line)',
      borderRadius: 12,
      background: open ? 'linear-gradient(180deg, oklch(0.3 0.08 170 / 0.18), oklch(0.18 0.014 265 / 0.55))' : 'oklch(0.18 0.014 265 / 0.55)',
      boxShadow: open ? '0 0 0 1px oklch(0.86 0.16 165 / 0.08)' : 'none',
      transition: 'background 0.2s, border-color 0.2s',
      overflow: 'hidden'
    }}>
      <button onClick={() => setOpen(!open)} style={{
        all: 'unset',
        cursor: 'pointer',
        width: '100%',
        boxSizing: 'border-box',
        padding: mobile ? '18px 20px' : '22px 26px',
        display: 'flex', alignItems: 'center', justifyContent: 'space-between', gap: 16
      }}>
        <span style={{
          fontFamily: 'var(--font-display)', fontSize: mobile ? 16 : 18, fontWeight: 500,
          letterSpacing: '-0.012em', color: 'var(--fg)', textWrap: 'balance', flex: 1
        }}>
          {q}
        </span>
        <svg width="18" height="18" viewBox="0 0 18 18" style={{
          flexShrink: 0,
          transform: open ? 'rotate(180deg)' : 'rotate(0deg)',
          transition: 'transform 0.2s',
          color: open ? 'var(--accent, var(--mint))' : 'var(--fg-3)'
        }} fill="none" stroke="currentColor" strokeWidth="1.6" strokeLinecap="round">
          <path d="M5 7l4 4 4-4" />
        </svg>
      </button>
      {open &&
      <div style={{
        padding: mobile ? '0 20px 20px' : '0 26px 24px',
        fontSize: mobile ? 14 : 15, color: 'var(--fg-2)', lineHeight: 1.65,
        textWrap: 'pretty'
      }}>
          {a}
        </div>
      }
    </article>);

}

function FAQ({ mobile = false }) {
  const items = [
  { q: 'What is AlgoVault?', a: 'AlgoVault is an MCP server that provides AI trading agents with composite BUY/SELL/HOLD trade calls, cross-venue funding rate arbitrage scanning, and market regime detection across 5 exchanges — Hyperliquid, Binance, Bybit, OKX, and Bitget. It works with any MCP-compatible client including Claude, Cursor, and custom agents.', open: true },
  { q: 'How does the trade call scoring work?', a: 'Each call is a multi-factor composite of trend persistence, breakout pressure, funding state, and volatility regime — scored on the same scale across crypto and TradFi. We only fire BUY/SELL when conviction clears the threshold; otherwise the call is HOLD (and HOLDs are free).' },
  { q: 'What exchanges does AlgoVault support?', a: 'Hyperliquid, Binance, Bybit, OKX, and Bitget. Hyperliquid is the source for TradFi perpetuals (TSLA, GOLD, SP500, etc.) via its xyz dex. Funding-rate arb covers Hyperliquid · Binance · Bybit.' },
  { q: 'Is AlgoVault free to use?', a: 'Yes — the Free tier covers all assets, all 11 timeframes, and 100 calls/month with no signup. HOLD calls are always free across every tier.' },
  { q: 'What is MCP (Model Context Protocol)?', a: 'MCP is an open protocol for connecting AI assistants to external tools and data sources. AlgoVault implements MCP so any compliant client (Claude, Cursor, Windsurf, custom agents) can call get_trade_call / scan_funding_arb / get_market_regime directly without bespoke integration.' }];

  return (
    <LRBlock id="faq" mobile={mobile}>
      <LREyebrow>· faq</LREyebrow>
      <LRH2 mobile={mobile}>Frequently asked.</LRH2>
      <div style={{ marginTop: mobile ? 24 : 40, display: 'flex', flexDirection: 'column', gap: 10, maxWidth: 920 }}>
        {items.map((it, i) =>
        <FAQItem key={i} q={it.q} a={it.a} defaultOpen={!!it.open} mobile={mobile} />
        )}
      </div>
    </LRBlock>);

}

