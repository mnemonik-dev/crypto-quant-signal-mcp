function ForDevelopers({ mobile = false }) {
  const cards = [
  {
    title: 'MCP / HTTP API',
    sub: 'For AI agents & production',
    code: <><span className="tk-com">// Remote — Streamable HTTP</span>{'\n'}https://api.algovault.com/mcp{'\n'}<span className="tk-com">// Local — stdio</span>{'\n'}$ npx -y crypto-quant-signal-mcp</>,
