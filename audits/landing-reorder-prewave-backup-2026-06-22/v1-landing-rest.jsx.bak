// AlgoVault landing — sections below "Why not just use exchange APIs?".
// Inherits hero tokens: dark bg, mint accent, Inter Tight + Inter + JetBrains Mono.
// Card primitives match v1-belowfold.jsx (1px solid var(--line), 14px radius, oklch(0.18 0.014 265 / 0.55)).

const LRBlock = ({ children, mobile, dim = false, id, py, ...rest }) =>
<section id={id} {...rest} style={{
  position: 'relative',
  padding: mobile ? `${py?.m ?? 64}px 22px` : `${py?.d ?? 120}px 80px`,
  borderTop: '1px solid var(--line)',
  background: dim ? 'linear-gradient(180deg, transparent, oklch(0.155 0.012 265 / 0.7) 30%, oklch(0.155 0.012 265 / 0.7) 70%, transparent)' : 'transparent'
}}>{children}</section>;


const LREyebrow = ({ children }) =>
<div style={{
  display: 'inline-flex', alignItems: 'center', gap: 10, marginBottom: 18,
  fontFamily: 'var(--font-mono)', fontSize: 11, color: 'var(--fg-3)',
  letterSpacing: '0.14em', textTransform: 'uppercase'
}}>
    <span style={{ width: 5, height: 5, borderRadius: '50%', background: 'var(--accent, var(--mint))', boxShadow: '0 0 8px var(--accent, var(--mint))' }} />
    {children}
  </div>;


const LRH2 = ({ children, mobile }) =>
<h2 style={{
  fontFamily: 'var(--font-display)',
  fontSize: mobile ? 30 : 48, lineHeight: 1.05,
  letterSpacing: '-0.022em', fontWeight: 500,
  margin: 0, textWrap: 'balance', color: 'var(--fg)'
}}>{children}</h2>;


const LRLead = ({ children, mobile, max = 720 }) =>
<p style={{
  fontSize: mobile ? 15 : 17, color: 'var(--fg-2)',
  maxWidth: max, margin: mobile ? '14px 0 32px' : '20px 0 56px',
  lineHeight: 1.6
}}>{children}</p>;


const Pill = ({ children, accent = 'mint', dim = false, mono = true, style }) =>
<span style={{
  display: 'inline-flex', alignItems: 'center', gap: 6,
  padding: '6px 11px', borderRadius: 999,
  border: `1px solid ${accent === 'violet' ? 'oklch(0.45 0.14 290 / 0.5)' : 'var(--line)'}`,
  background: dim ? 'oklch(0.13 0.012 265 / 0.7)' : 'oklch(0.2 0.012 265 / 0.65)',
  fontFamily: mono ? 'var(--font-mono)' : 'var(--font-display)',
  fontSize: 11.5,
  color: accent === 'violet' ? 'var(--violet)' : 'var(--accent, var(--mint))',
  ...style
}}>{children}</span>;


const Check = ({ size = 14 }) =>
<svg width={size} height={size} viewBox="0 0 16 16" fill="none" style={{ flexShrink: 0, marginTop: 3 }}>
    <path d="M3 8.5l3.2 3L13 4.5" stroke="var(--accent, var(--mint))" strokeWidth="1.6" strokeLinecap="round" strokeLinejoin="round" />
  </svg>;


const Bullet = ({ children, mobile }) =>
<li style={{ display: 'flex', gap: 10, alignItems: 'flex-start', fontSize: mobile ? 13.5 : 14.5, color: 'var(--fg-2)', lineHeight: 1.5 }}>
    <Check /><span>{children}</span>
  </li>;


/* ================================================================
   1. TRY IT IN 30 SECONDS  — 3 step quickstart + JSON snippet
   ================================================================ */
function TryIn30({ mobile = false }) {
  const steps = [
  {
    title: 'Open Claude → Settings → Integrations',
    sub: 'Or any MCP-compatible client: Cursor, Windsurf, VS Code, etc.'
  },
  {
    title: 'Add custom integration → paste the URL',
    sub: 'https://api.algovault.com/mcp',
    copyable: 'https://api.algovault.com/mcp'
  },
  {
    title: 'Ask Claude',
    sub: '"Get me a trade call for BTC on the 15m timeframe"',
    tag: 'Free tier: all assets, all 11 timeframes, 100 calls/month'
  }];

  return (
    <LRBlock id="try-it" mobile={mobile}>
      <LREyebrow>· quickstart</LREyebrow>
      <LRH2 mobile={mobile}>Try it in 30 seconds.</LRH2>
      <LRLead mobile={mobile}>Three steps from idle Claude to live verdict. No SDK, no auth handshake, no cold-start.</LRLead>

      {/* Step list */}
      <div style={{
        display: 'grid',
        gridTemplateColumns: mobile ? '1fr' : 'repeat(3, 1fr)',
        gap: mobile ? 14 : 20,
        marginBottom: mobile ? 28 : 44
      }}>
        {steps.map((s, i) =>
        <article key={i} style={{
          position: 'relative',
          padding: mobile ? '22px 20px' : '32px 30px',
          border: '1px solid var(--line)', borderRadius: 14,
          background: 'oklch(0.18 0.014 265 / 0.55)',
          display: 'flex', flexDirection: 'column', gap: 14
        }}>
            <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
              <div style={{
              width: 36, height: 36, borderRadius: 999,
              background: 'oklch(0.22 0.012 265)',
              border: '1px solid var(--accent, var(--mint))',
              display: 'grid', placeItems: 'center',
              fontFamily: 'var(--font-mono)', fontSize: 13, fontWeight: 600,
              color: 'var(--accent, var(--mint))',
              boxShadow: '0 0 14px oklch(0.86 0.16 165 / 0.25)'
            }}>0{i + 1}</div>
              {s.copyable &&
            <button onClick={(e) => navigator.clipboard?.writeText(s.copyable)} style={{
              border: '1px solid var(--line-2)', background: 'oklch(0.22 0.012 265 / 0.6)',
              color: 'var(--fg-2)', cursor: 'pointer', padding: '5px 10px',
              borderRadius: 7, fontFamily: 'var(--font-mono)', fontSize: 10.5, letterSpacing: '0.08em'
            }}>COPY</button>
            }
            </div>
            <div>
              <div style={{ fontFamily: 'var(--font-display)', fontSize: mobile ? 17 : 19, fontWeight: 500, color: 'var(--fg)', letterSpacing: '-0.012em', marginBottom: 8, textWrap: 'balance' }}>
                {s.title}
              </div>
              <div style={{
              fontSize: 13.5, color: i === 1 ? 'var(--accent, var(--mint))' : 'var(--fg-2)',
              fontFamily: i === 1 ? 'var(--font-mono)' : 'var(--font-text)',
              lineHeight: 1.55,
              wordBreak: i === 1 ? 'break-all' : 'normal'
            }}>{s.sub}</div>
            </div>
            {s.tag &&
          <div style={{ fontSize: 11.5, color: 'var(--fg-3)', borderTop: '1px solid var(--line)', paddingTop: 12, marginTop: 'auto' }}>
                {s.tag}
              </div>
          }
          </article>
        )}
      </div>

      {/* Code response block */}
      <div className="code-window" style={{ fontSize: mobile ? 11.5 : 13 }}>
        <div className="code-window-header">
          <span className="code-dot" style={{ background: '#ff5f57' }} />
          <span className="code-dot" style={{ background: '#febc2e' }} />
          <span className="code-dot" style={{ background: '#28c840' }} />
          <span style={{ marginLeft: 12 }}>get_trade_call(<span className="tk-str">"BTC"</span>, <span className="tk-str">"15m"</span>) → response</span>
          <span style={{ marginLeft: 'auto', color: 'var(--accent, var(--mint))', fontFamily: 'var(--font-mono)', fontSize: 10.5 }}>● 312ms · 200 OK</span>
        </div>
        <div className="code-body" style={{ padding: mobile ? '14px 16px' : '20px 24px' }}>
{[
          ['{', ''],
          ['  "asset": "BTC",', '  "timeframe": "15m",'],
          ['  "call": "BUY",', '  "confidence": 0.74,'],
          ['  "regime": "trending_up",', '  "factors": {'],
          ['    "trend_persistence": "HIGH",', '    "funding_state": "NEUTRAL",'],
          ['    "breakout_pending": "ACTIVE",', '    "volatility_regime": "normal",'],
          ['  },', '  "merkle_id": "0x4a2…f91"'],
          ['}', '']].
          map(([a, b], i) => {
            const tokenize = (line) => line.split(/("[^"]*"|\b\d+\.?\d*\b|[{}\[\],:])/).map((t, k) => {
              if (!t) return null;
              if (/^"[^"]*"$/.test(t)) {
                const isKey = i < 7 && line.indexOf(t) < line.indexOf(':');
                return <span key={k} className={isKey ? 'tk-key' : 'tk-str'}>{t}</span>;
              }
              if (/^\d+\.?\d*$/.test(t)) return <span key={k} className="tk-num">{t}</span>;
              if (/^[{}\[\],:]$/.test(t)) return <span key={k} className="tk-pun">{t}</span>;
              return <span key={k}>{t}</span>;
            });
            return (
              <div key={i} className="code-line" style={{ display: mobile ? 'block' : 'flex', gap: mobile ? 0 : 60, opacity: a || b ? 1 : 0.4 }}>
      <div style={{ flex: 1 }}>{tokenize(a)}</div>
      {!mobile && <div style={{ flex: 1 }}>{tokenize(b)}</div>}
      {mobile && b && <div>{tokenize(b)}</div>}
    </div>);

          })}
        </div>
      </div>
    </LRBlock>);

}

/* ================================================================
   2. TRADFI PERPETUALS — purple callout
   ================================================================ */
function TradFiCallout({ mobile = false }) {
  return (
    <section style={{
      padding: mobile ? '0 22px 56px' : '0 80px 96px',
      position: 'relative'
    }}>
      <div style={{
        position: 'relative',
        padding: mobile ? '22px 22px' : '28px 32px',
        border: '1px solid oklch(0.5 0.16 290 / 0.45)',
        borderRadius: 14,
        background: 'linear-gradient(180deg, oklch(0.32 0.1 290 / 0.18), oklch(0.18 0.014 265 / 0.55))',
        boxShadow: '0 0 0 1px oklch(0.62 0.18 290 / 0.08), 0 14px 40px -22px oklch(0.62 0.18 290 / 0.5)',
        display: mobile ? 'block' : 'grid',
        gridTemplateColumns: '180px 1fr',
        alignItems: 'center', gap: 24
      }}>
        <div style={{ display: 'flex', alignItems: 'center', gap: 10, marginBottom: mobile ? 12 : 0 }}>
          <span style={{
            width: 38, height: 38, borderRadius: 9,
            display: 'grid', placeItems: 'center',
            background: 'oklch(0.32 0.1 290 / 0.4)',
            border: '1px solid oklch(0.5 0.14 290 / 0.5)'
          }}>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M3 14V6h2v8H3zm4-3V6h2v5H7zm4-7v10h2V4h-2zm4 4v6h2V8h-2z" fill="oklch(0.78 0.16 290)" />
            </svg>
          </span>
          <div>
            <div style={{ fontFamily: 'var(--font-mono)', fontSize: 10.5, color: 'var(--fg-4)', letterSpacing: '0.14em', textTransform: 'uppercase', marginBottom: 4 }}>· also</div>
            <div style={{ fontFamily: 'var(--font-display)', fontSize: mobile ? 18 : 20, fontWeight: 500, letterSpacing: '-0.012em', color: 'oklch(0.85 0.13 290)' }}>
              TradFi Perpetuals
            </div>
          </div>
        </div>
        <div style={{ fontSize: mobile ? 14 : 15, color: 'var(--fg-2)', lineHeight: 1.55 }}>
          Stocks, commodities, indices, and FX via Hyperliquid&rsquo;s xyz dex. Trade calls for{' '}
          <span style={{ color: 'oklch(0.85 0.13 290)', fontFamily: 'var(--font-mono)', fontSize: mobile ? 12.5 : 13 }}>TSLA</span>,{' '}
          <span style={{ color: 'oklch(0.85 0.13 290)', fontFamily: 'var(--font-mono)', fontSize: mobile ? 12.5 : 13 }}>GOLD</span>,{' '}
          <span style={{ color: 'oklch(0.85 0.13 290)', fontFamily: 'var(--font-mono)', fontSize: mobile ? 12.5 : 13 }}>SP500</span>, and more.
        </div>
      </div>
    </section>);

}

/* ================================================================
   3. THREE TOOLS, ONE VERDICT
   ================================================================ */
function ThreeTools({ mobile = false }) {
  const cards = [
  {
    tool: 'get_trade_call',
    title: 'Composite Trade Call',
    bullets: ['Multi-factor composite scoring', 'Regime-aware filtering', 'Crypto + TradFi', '11 timeframes (1m–1d)'],
    snippet: <>→ <span style={{ color: 'var(--green)' }}>BUY 68%</span> · trend_persistence: <span style={{ color: 'oklch(0.82 0.12 65)' }}>HIGH</span> · funding_state: <span style={{ color: 'oklch(0.82 0.12 65)' }}>ELEVATED</span> · breakout_pending: <span style={{ color: 'var(--fg-3)' }}>INACTIVE</span></>
  },
  {
    tool: 'scan_funding_arb',
    title: 'Funding Rate Arbitrage',
    bullets: ['Hyperliquid vs Binance vs Bybit', 'Normalized hourly rates', 'Annualized spreads in basis points', 'Ranked by opportunity size'],
    snippet: <>→ <span style={{ color: 'var(--accent, var(--mint))' }}>DOGE +42 bps</span> spread · HL <span style={{ color: 'oklch(0.82 0.12 65)' }}>+0.83%</span> vs Binance <span style={{ color: 'var(--fg-3)' }}>+0.01%</span></>
  },
  {
    tool: 'get_market_regime',
    title: 'Market Regime Detection',
    bullets: ['Trending / Ranging / Volatile', 'Multi-dimensional classification', 'Cross-venue funding sentiment', 'Strategy & sizing suggestions'],
    snippet: <>→ <span style={{ color: 'var(--green)' }}>TRENDING_UP</span> ADX=<span style={{ color: 'oklch(0.82 0.12 65)' }}>34.2</span> · Funding sentiment: <span style={{ color: 'var(--accent, var(--mint))' }}>BULLISH_BIAS</span></>
  }];

  return (
    <LRBlock id="three-tools" mobile={mobile} dim>
      <LREyebrow>· tools</LREyebrow>
      <LRH2 mobile={mobile}>3 tools, one verdict.</LRH2>
      <LRLead mobile={mobile}>
        Each tool combines multiple data sources into a single, actionable answer.<br/>Assets are classified into quality tiers with institutional-grade liquidity filtering.
      </LRLead>
      <div style={{
        display: 'grid',
        gridTemplateColumns: mobile ? '1fr' : 'repeat(3, 1fr)',
        gap: mobile ? 14 : 20
      }}>
        {cards.map((c, i) =>
        <article key={i} style={{
          padding: mobile ? '20px 20px 22px' : '28px 28px 24px',
          border: '1px solid var(--line)', borderRadius: 14,
          background: 'oklch(0.18 0.014 265 / 0.55)',
          display: 'flex', flexDirection: 'column', gap: mobile ? 14 : 18
        }}>
            <Pill dim style={{ alignSelf: 'flex-start' }}>
              <span style={{ color: 'var(--fg-4)' }}>›</span>{c.tool}
            </Pill>
            <div style={{ fontFamily: 'var(--font-display)', fontSize: mobile ? 19 : 22, fontWeight: 500, letterSpacing: '-0.014em', color: 'var(--fg)' }}>
              {c.title}
            </div>
            <ul style={{ listStyle: 'none', padding: 0, margin: 0, display: 'flex', flexDirection: 'column', gap: 8 }}>
              {c.bullets.map((b, j) => <Bullet key={j} mobile={mobile}>{b}</Bullet>)}
            </ul>
            <div style={{
            marginTop: 'auto',
            padding: mobile ? '12px 12px' : '14px 14px',
            borderRadius: 10, border: '1px solid var(--line)',
            background: 'oklch(0.13 0.01 265)',
            fontFamily: 'var(--font-mono)', fontSize: mobile ? 11 : 11.5,
            lineHeight: 1.5, color: 'var(--fg-2)',
            wordBreak: 'break-word'
          }}>
              {c.snippet}
            </div>
          </article>
        )}
      </div>
    </LRBlock>);

}

/* ================================================================
   4. USE CASES — Brain + Execution Pairing (4 exchange cards)
   ================================================================ */
function UseCases({ mobile = false }) {
  const cards = [
  { ex: 'Binance', mark: 'B', stripe: 'oklch(0.82 0.16 85)', body: 'Composite verdict + official Binance Skills Hub for Spot Testnet execution', pkg: 'binance/binance-skills-hub', meta: 'verified 2026-04-26' },
  { ex: 'OKX', mark: 'O', stripe: 'oklch(0.82 0.005 265)', body: 'Composite verdict + 83 OKX execution tools across spot, swap, futures, options, grid bots', pkg: '@okx_ai/okx-trade-mcp@1.3.1', meta: '83 tools' },
  { ex: 'Bybit', mark: 'BY', stripe: 'oklch(0.74 0.18 35)', body: "Composite verdict + Bybit's official MCP for Linear Perpetual + conditional orders", pkg: 'bybit-official-trading-server@1.0.9', meta: 'linear perp · conditional' },
  { ex: 'Bitget', mark: 'BG', stripe: 'oklch(0.78 0.13 200)', body: 'Composite verdict + GetClaw agent-native execution inside a dedicated AI account', pkg: 'bitget-mcp-server@1.1.0', meta: 'GetClaw · AI account' }];

  return (
    <LRBlock id="use-cases" mobile={mobile}>
      <LREyebrow>· use cases</LREyebrow>
      <LRH2 mobile={mobile}>Brain + execution pairing.</LRH2>
      <LRLead mobile={mobile} max={780}>
        AlgoVault MCP gives your agent a composite verdict in one call — call, confidence, regime, factors, every call Merkle-anchored on Base L2. Pair it with any of these official Agent Trade Kits to ship a complete trading agent.
      </LRLead>
      <div style={{
        display: 'grid',
        gridTemplateColumns: mobile ? '1fr' : 'repeat(4, 1fr)',
        gap: mobile ? 14 : 16
      }}>
        {cards.map((c, i) =>
        <article key={i} style={{
          position: 'relative',
          padding: mobile ? '20px 20px' : '24px 22px 22px',
          border: '1px solid var(--line)', borderRadius: 14,
          background: 'oklch(0.18 0.014 265 / 0.55)',
          display: 'flex', flexDirection: 'column', gap: 14,
          overflow: 'hidden'
        }}>
            <div style={{
            position: 'absolute', top: 0, left: 0, right: 0, height: 2,
            background: c.stripe,
            opacity: 0.85
          }} />
            <div style={{ display: 'flex', alignItems: 'center', gap: 10 }}>
              <span className="xchg-mark" style={{ '--mark': c.stripe, width: 28, height: 28, fontSize: 11 }}>{c.mark}</span>
              <div style={{ display: 'flex', flexDirection: 'column' }}>
                <span style={{ fontFamily: 'var(--font-display)', fontSize: mobile ? 17 : 18, fontWeight: 500, letterSpacing: '-0.012em', color: 'var(--fg)' }}>
                  {c.ex} × AlgoVault
                </span>
                <span style={{ fontFamily: 'var(--font-mono)', fontSize: 10, color: 'var(--fg-4)', letterSpacing: '0.06em' }}>
                  {c.meta}
                </span>
              </div>
            </div>
            <p style={{ margin: 0, fontSize: mobile ? 13.5 : 14, color: 'var(--fg-2)', lineHeight: 1.5 }}>
              {c.body}
            </p>
            <div style={{
            marginTop: 'auto', display: 'flex', flexDirection: 'column', gap: 10,
            paddingTop: 12, borderTop: '1px solid var(--line)'
          }}>
              <span style={{ fontFamily: 'var(--font-mono)', fontSize: 11, color: 'var(--fg-3)', wordBreak: 'break-all', lineHeight: 1.4 }}>
                {c.pkg}
              </span>
              <a href="#tutorial" style={{ fontFamily: 'var(--font-text)', fontSize: 13, color: 'var(--accent, var(--mint))', textDecoration: 'none', display: 'inline-flex', alignItems: 'center', gap: 5 }}>
                View tutorial <span style={{ fontFamily: 'var(--font-mono)' }}>→</span>
              </a>
            </div>
          </article>
        )}
      </div>
      <p style={{
        marginTop: mobile ? 22 : 32, fontSize: 11.5, color: 'var(--fg-4)',
        lineHeight: 1.55, maxWidth: 880
      }}>
        All demos run testnet/demo only — zero real-money risk in any code path. AlgoVault returns analytics; your agent and risk policy decide what to execute. Exchange logos and names are trademarks of their respective owners. Used for nominative reference to integration tutorials. No partnership or endorsement implied.
      </p>
    </LRBlock>);

}

/* ================================================================
   5. LIVE TRACK RECORD — stat dashboard
   ================================================================ */
function LiveTrackRecord({ mobile = false }) {
  const top = [
  { big: 'Every Trade Call', small: 'Tracked & Measured' },
  { big: 'Crypto + TradFi', small: 'Asset Coverage' },
  { big: '11 Timeframes', small: '1m – 1d' },
  { big: '5 Exchanges', small: 'Analyzed' }];

  const mid = [
  { big: '1m – 1d', small: 'All HL intervals' },
  { big: '≥ 60%', small: 'Confidence filter' },
  { big: 'PFE Win Rate', small: 'Peak Favorable Excursion' },
  { big: 'Per-TF Evaluation', small: '5m/1hr · 1hr/8hr · 4hr/24hr' }];

  const live = [
  { big: '90.2%', small: 'PFE Win Rate', live: true },
  { big: '80,059+', small: 'Verified Calls', live: true },
  { big: '29', small: 'Merkle batches on-chain', live: true }];

  const StatCard = ({ big, small, live, accent, large }) =>
  <div style={{
    padding: mobile ? '18px 18px' : '22px 22px',
    border: live ? '1px solid oklch(0.7 0.14 165 / 0.45)' : '1px solid var(--line)',
    borderRadius: 12,
    background: live ?
    'linear-gradient(180deg, oklch(0.32 0.08 170 / 0.22), oklch(0.18 0.014 265 / 0.55))' :
    'oklch(0.18 0.014 265 / 0.55)',
    display: 'flex', flexDirection: 'column', gap: 6,
    boxShadow: live ? '0 0 0 1px oklch(0.86 0.16 165 / 0.08), 0 12px 30px -18px oklch(0.86 0.16 165 / 0.4)' : 'none',
    position: 'relative', overflow: 'hidden'
  }}>
      {live &&
    <span style={{
      position: 'absolute', top: 12, right: 14,
      fontFamily: 'var(--font-mono)', fontSize: 9.5, color: 'var(--green)',
      letterSpacing: '0.16em', display: 'inline-flex', alignItems: 'center', gap: 5
    }}>
          <span className="live-pulse" style={{ width: 5, height: 5 }} />LIVE
        </span>
    }
      <div style={{
      fontFamily: 'var(--font-display)',
      fontSize: large ? mobile ? 28 : 38 : mobile ? 19 : 22,
      fontWeight: large ? 600 : 500,
      letterSpacing: '-0.018em',
      color: live ? 'var(--accent, var(--mint))' : 'var(--fg)',
      textShadow: live ? '0 0 18px oklch(0.86 0.16 165 / 0.35)' : 'none'
    }}>
        {big}
      </div>
      <div style={{
      fontFamily: 'var(--font-mono)', fontSize: 10.5, color: 'var(--fg-3)',
      letterSpacing: '0.08em', textTransform: 'uppercase'
    }}>
        {small}
      </div>
    </div>;

  return (
    <LRBlock id="track-record" mobile={mobile}>
      <LREyebrow>· live track record</LREyebrow>
      <LRH2 mobile={mobile}>Every qualifying call, on the record.</LRH2>
      <LRLead mobile={mobile} max={780}>
        Every qualifying trade call (confidence ≥ 60%) is tracked. PFE directional accuracy and excursion analysis. All public.
      </LRLead>

      <div style={{ display: 'grid', gridTemplateColumns: mobile ? '1fr 1fr' : 'repeat(4, 1fr)', gap: mobile ? 10 : 14, marginBottom: mobile ? 12 : 14 }}>
        {top.map((t, i) => <StatCard key={i} {...t} />)}
      </div>
      <div style={{ display: 'grid', gridTemplateColumns: mobile ? '1fr 1fr' : 'repeat(4, 1fr)', gap: mobile ? 10 : 14, marginBottom: mobile ? 18 : 22 }}>
        {mid.map((t, i) => <StatCard key={i} {...t} />)}
      </div>
      <div style={{ display: 'grid', gridTemplateColumns: mobile ? '1fr' : 'repeat(3, 1fr)', gap: mobile ? 10 : 14 }}>
        {live.map((t, i) => <StatCard key={i} {...t} large />)}
      </div>

      <div style={{ marginTop: mobile ? 26 : 36, display: 'flex', alignItems: 'center', flexWrap: 'wrap', gap: 16 }}>
        <a href="#track" className="btn btn-primary accent-cyan" style={{ background: 'var(--accent, var(--mint))', color: 'oklch(0.16 0.05 165)', boxShadow: 'inset 0 1px 0 oklch(1 0 0 / 0.3), 0 0 0 1px oklch(0.96 0.05 165 / 0.25), 0 8px 30px -10px oklch(0.86 0.16 165 / 0.55)' }}>
          View Live Track Record →
        </a>
        <span style={{ fontSize: 12.5, color: 'var(--fg-3)', maxWidth: 520, lineHeight: 1.5 }}>
          Updated live. Also queryable via{' '}
          <span style={{ fontFamily: 'var(--font-mono)', color: 'var(--fg-2)' }}>performance://signal-performance</span>{' '}
          MCP resource.
        </span>
      </div>
      {/* DESIGN-W7 fix-forward ROUND 8 (Mr.1 directive 2026-05-11): On-chain verified P
          REMOVED per visual review — duplicates content of the Tamper-Proof Track Record
          callout immediately below; Verify-any-call CTA now lives on that callout. */}
    </LRBlock>);

}

/* ================================================================
