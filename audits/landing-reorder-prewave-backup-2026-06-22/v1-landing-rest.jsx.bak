  };
  return (
    <section style={{ padding: mobile ? '0 22px 6px' : '0 80px 8px' }}>
      <div style={{
        padding: mobile ? '18px 18px' : '22px 26px',
        border: '1px solid oklch(0.5 0.14 165 / 0.45)', borderRadius: 14,
        background: 'linear-gradient(90deg, oklch(0.32 0.08 170 / 0.25), oklch(0.18 0.014 265 / 0.55))',
        display: 'flex', flexDirection: 'column', gap: mobile ? 14 : 16
      }}>
