/* ================================================================
   4b. LIVE VERDICT — styled "verdict-with-receipts" example card
   (P2-LANDING-VERDICT-CARD-W1). DEMONSTRATIVE-FROM-REAL-EVENT: a REAL
   captured get_trade_call snapshot (AXS · 1h · BUY 60, 2026-06-20; see
   audits/p2-example-call-2026-06-20.json) baked STATIC + labeled
   "Example output". The Proof-line PFE WR + call count are LIVE-bound via
   the EXISTING data-tr-field hydration (track-record-proxy.js) — never
   hardcoded. Field set + tooltip/disclaimer copy mirror the P0
   src/lib/receipts.ts Receipts contract + RECEIPTS_* constants (verbatim;
   asserted byte-equal by tests/unit/landing-verdict-card.test.ts). Card
   chrome reuses .glow / .card-hover / .fade-in (NO new CSS).
   ================================================================ */
// Verbatim P0 RECEIPTS_* SoT (src/lib/receipts.ts) — kept byte-identical (test-asserted).
const RECEIPTS_BADGE_TOOLTIP = 'Every call is logged and Merkle-anchored on Base. Check it yourself.';
const RECEIPTS_CONVICTION_TOOLTIP = "Conviction is our model's confidence in an actionable setup — not a probability of profit.";
const RECEIPTS_DISCLAIMER = 'Informational analytics, not investment advice. Past performance does not guarantee future results.';

function LiveVerdict({ mobile = false }) {
  // Top factors from the captured _receipts (faithful enum values, mono "Example output" styling).
  const factors = [
    { label: 'Trend persistence', value: 'HIGH', dir: 'neutral' },
    { label: 'Funding', value: 'ELEVATED', dir: 'bullish' },
    { label: 'Open interest', value: '+18.1%', dir: 'bullish' }];

  const dirColor = (d) => d === 'bullish' ? 'var(--accent, var(--mint))' : d === 'bearish' ? 'oklch(0.65 0.2 18)' : 'var(--fg-3)';
  const dirGlyph = (d) => d === 'bullish' ? '↑' : d === 'bearish' ? '↓' : '·';
  // VERBATIM reasoning string from the captured call (Q-P2-2: no placeholder).
  const why = 'Trending regime, upward bias. Funding pressure elevated; one-sided crowd forming. Volatility neither expanding nor compressed. Trend persistence elevated; momentum structure. Moderate conviction from blended signals.';

  return (
    <LRBlock id="live-verdict" mobile={mobile}>
      <LREyebrow>· live verdict</LREyebrow>
      <LRH2 mobile={mobile}>One call. One verdict. <span style={{ color: 'var(--accent, var(--mint))' }}>Verifiable.</span></LRH2>
      <LRLead mobile={mobile} max={760}>Direction, conviction, and the drivers behind it — with a track record you can verify yourself.</LRLead>

      <div className="glow card-hover fade-in" style={{
        position: 'relative', maxWidth: mobile ? '100%' : 580,
        padding: mobile ? '22px 20px' : '28px 30px',
        border: '1px solid oklch(0.5 0.14 165 / 0.5)', borderRadius: 16,
        background: 'linear-gradient(180deg, oklch(0.22 0.04 168 / 0.32), oklch(0.18 0.014 265 / 0.62))',
        display: 'flex', flexDirection: 'column', gap: mobile ? 15 : 17
      }}>
        <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', gap: 12 }}>
          <span style={{ fontFamily: 'var(--font-mono)', fontSize: mobile ? 11.5 : 12.5, color: 'var(--fg-3)', letterSpacing: '0.04em' }}>AXS · 1h · Binance</span>
          <span style={{ fontFamily: 'var(--font-mono)', fontSize: 9.5, color: 'var(--fg-3)', letterSpacing: '0.16em', textTransform: 'uppercase', padding: '4px 10px', border: '1px solid var(--line)', borderRadius: 999, background: 'oklch(0.13 0.012 265 / 0.7)', whiteSpace: 'nowrap' }}>Example output</span>
        </div>

        <div style={{ display: 'flex', alignItems: 'baseline', flexWrap: 'wrap', gap: mobile ? 7 : 11 }}>
          <span style={{ fontFamily: 'var(--font-display)', fontSize: mobile ? 32 : 40, fontWeight: 600, letterSpacing: '-0.02em', color: 'var(--accent, var(--mint))', textShadow: '0 0 22px oklch(0.86 0.16 165 / 0.35)', lineHeight: 1 }}>BUY</span>
          <span title={RECEIPTS_CONVICTION_TOOLTIP} style={{ fontFamily: 'var(--font-display)', fontSize: mobile ? 17 : 20, fontWeight: 500, color: 'var(--fg-2)', cursor: 'help' }}>· 60% conviction</span>
          <span style={{ fontSize: mobile ? 13.5 : 15, color: 'var(--fg-3)' }}>— Trending up</span>
        </div>

        <div style={{ display: 'flex', flexWrap: 'wrap', gap: mobile ? 8 : 10 }}>
          {factors.map((f, i) =>
          <span key={i} style={{ display: 'inline-flex', alignItems: 'center', gap: 6, padding: '6px 11px', borderRadius: 8, border: '1px solid var(--line)', background: 'oklch(0.2 0.012 265 / 0.6)', fontFamily: 'var(--font-mono)', fontSize: 11.5, color: 'var(--fg-2)' }}>
              {f.label} <span style={{ color: dirColor(f.dir), fontWeight: 600 }}>{f.value} {dirGlyph(f.dir)}</span>
            </span>
          )}
        </div>

        <div style={{ fontSize: mobile ? 13 : 13.5, color: 'var(--fg-2)', lineHeight: 1.55 }}>
          <span style={{ color: 'var(--fg-3)', fontFamily: 'var(--font-mono)', fontSize: 10.5, textTransform: 'uppercase', letterSpacing: '0.1em', marginRight: 8 }}>Why</span>
          {why}
        </div>

        <div style={{ height: 1, background: 'var(--line)', margin: '2px 0' }} />

        <div style={{ display: 'flex', flexWrap: 'wrap', alignItems: 'center', gap: mobile ? 8 : 10, fontSize: mobile ? 12.5 : 13.5, color: 'var(--fg-2)', fontFamily: 'var(--font-mono)' }}>
          <span title={RECEIPTS_BADGE_TOOLTIP} style={{ cursor: 'help' }}>
            <span data-tr-field="pfe_wr" style={{ color: 'var(--accent, var(--mint))', fontWeight: 600 }}>91.5%</span> PFE win rate · <span data-tr-field="call_count">246,980</span> calls · Merkle-anchored on Base
          </span>
          <span style={{ flexGrow: 1 }} />
          <a href="/track-record" style={{ color: 'var(--accent, var(--mint))', textDecoration: 'none', whiteSpace: 'nowrap' }}>Verify →</a>
        </div>
      </div>

      <div style={{ marginTop: mobile ? 20 : 26, display: 'flex', flexDirection: 'column', gap: 12 }}>
        <a href="/track-record" className="btn btn-primary accent-cyan" style={{ alignSelf: 'flex-start', background: 'var(--accent, var(--mint))', color: 'oklch(0.16 0.05 165)', boxShadow: 'inset 0 1px 0 oklch(1 0 0 / 0.3), 0 0 0 1px oklch(0.96 0.05 165 / 0.25), 0 8px 30px -10px oklch(0.86 0.16 165 / 0.55)' }}>
          View Live Track Record →
        </a>
        <span style={{ fontSize: 11.5, color: 'var(--fg-3)', lineHeight: 1.5, maxWidth: 640 }}>{RECEIPTS_DISCLAIMER}</span>
      </div>
    </LRBlock>);

}

/* ================================================================
   COMPOSED — full landing rest (sections 1-9 + footer)
   ================================================================ */
function AlgoVaultLandingRest({ mobile = false }) {
  return (
    <div style={{ position: 'relative', zIndex: 1 }}>
      <TryIn30 mobile={mobile} />
      <TradFiCallout mobile={mobile} />
      <ThreeTools mobile={mobile} />
      <UseCases mobile={mobile} />
      <LiveVerdict mobile={mobile} />
      <LiveTrackRecord mobile={mobile} />
      <TamperProof mobile={mobile} />
      <TrustBand mobile={mobile} />
      <SimplePricing mobile={mobile} />
      <ForDevelopers mobile={mobile} />
      <FAQ mobile={mobile} />
      <LandingFooter mobile={mobile} />
    </div>);

}

Object.assign(window, {
  AlgoVaultLandingRest,
  TryIn30, TradFiCallout, ThreeTools, UseCases, LiveVerdict,
  LiveTrackRecord, TamperProof, TrustBand, SimplePricing,
  ForDevelopers, FAQ, LandingFooter
});