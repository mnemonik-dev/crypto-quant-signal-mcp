          <a href="https://basescan.org/token/0x8004A169FB4a3325136EB29fA0ceB6D2e539a432?a=44544" target="_blank" rel="noopener noreferrer" style={badge}>
            ERC-8004 Verified Agent · #<span data-tr-field="erc8004_agent_id">44544</span>
