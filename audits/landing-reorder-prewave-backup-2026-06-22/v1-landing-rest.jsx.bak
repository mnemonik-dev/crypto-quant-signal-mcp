      </LRLead>
      <div style={{
        display: 'grid',
        gridTemplateColumns: mobile ? '1fr' : 'repeat(3, 1fr)',
        gap: mobile ? 14 : 18
      }}>
        {cards.map((c, i) =>
        <article key={i} style={{
          padding: mobile ? '20px 20px' : '24px 22px 22px',
          border: '1px solid var(--line)', borderRadius: 14,
          background: 'oklch(0.18 0.014 265 / 0.55)',
          display: 'flex', flexDirection: 'column', gap: 14,
          minHeight: mobile ? 'auto' : 240
        }}>
            <div>
              <div style={{ fontFamily: 'var(--font-display)', fontSize: mobile ? 17 : 18, fontWeight: 500, color: 'var(--accent, var(--mint))', letterSpacing: '-0.012em' }}>
                {c.title}
              </div>
              <div style={{ fontSize: 12, color: 'var(--fg-3)', marginTop: 4 }}>{c.sub}</div>
            </div>
            <pre style={{
            margin: 0, padding: '12px 14px', borderRadius: 10,
            border: '1px solid var(--line)', background: 'oklch(0.13 0.01 265)',
            fontFamily: 'var(--font-mono)', fontSize: mobile ? 11 : 11.5,
            lineHeight: 1.55, color: 'var(--fg-2)',
