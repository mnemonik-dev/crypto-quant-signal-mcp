  {
    title: 'Webhooks',
    sub: 'Push delivery — no polling',
    code: <><span className="tk-com">// POST /api/webhooks  · needs your av_live_ key</span>{'\n'}events: trade_call · regime_shift · scan_digest{'\n'}filter: timeframe · exchange · cadence · top-N</>,
    foot: <>Subscribe once; every matching call is POSTed to your endpoint.{' '}<a href="/docs.html#webhooks" style={{ color: 'var(--accent, var(--mint))', textDecoration: 'none' }}>Webhooks docs →</a></>
  },
  {
    title: 'x402',
    sub: 'Pay-per-call · no signup',
    code: <><span className="tk-com">// Agent pays per call — USDC on Base</span>{'\n'}402 Payment Required → settle → 200 OK</>,
    foot: <>No key, no subscription — your agent's wallet pays per call.{' '}<a href="/docs.html#x402" style={{ color: 'var(--accent, var(--mint))', textDecoration: 'none' }}>x402 setup →</a></>
