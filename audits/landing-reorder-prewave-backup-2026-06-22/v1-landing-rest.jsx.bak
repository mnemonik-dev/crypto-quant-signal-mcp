    </section>);

}

/* ================================================================
   7. SIMPLE PRICING — 5 tier row
   ================================================================ */
function SimplePricing({ mobile = false }) {
  const tiers = [
  { id: 'free', name: 'FREE', price: '$0', sub: 'No signup needed',
    bullets: ['All crypto + TradFi assets', 'All 11 timeframes (1m–1d)', 'Top 5 funding arbs', '100 calls/month', 'HOLD calls always free'],
    cta: 'Start Free', href: '#quickstart', meta: 'Try the free Telegram bot →',
    stripe: 'oklch(0.78 0.18 145)', ctaStyle: 'ghost' },
  { id: 'starter', name: 'STARTER', price: '$9.99', period: '/mo', sub: 'For indie builders',
    bullets: ['All crypto + TradFi assets', 'All 11 timeframes', '3,000 calls/month', '$0.015/call overage', 'HOLD calls always free'],
    cta: 'Subscribe to Starter', href: 'https://api.algovault.com/signup?plan=starter&upgrade_from=landing_pricing', stripe: 'oklch(0.78 0.13 175)', ctaStyle: 'mint' },
  { id: 'pro', name: 'PRO', price: '$49', period: '/mo', sub: 'For serious agent builders', popular: true,
    bullets: ['All crypto + TradFi assets', 'All 11 timeframes (1m–1d)', '15,000 calls/month', '$0.01/call overage', 'HOLD calls always free'],
    cta: 'Subscribe to Pro', href: 'https://api.algovault.com/signup?plan=pro&upgrade_from=landing_pricing', stripe: 'oklch(0.86 0.16 165)', ctaStyle: 'mint-strong' },
  { id: 'enterprise', name: 'ENTERPRISE', price: '$299', period: '/mo', sub: 'For production trading desks',
    bullets: ['All crypto + TradFi assets', 'All 11 timeframes (1m–1d)', '100,000 calls/month', '$0.005/call overage', 'SLA + priority support', 'Unlimited funding arbs', 'HOLD calls always free'],
    cta: 'Subscribe to Enterprise', href: 'https://api.algovault.com/signup?plan=enterprise&upgrade_from=landing_pricing', stripe: 'oklch(0.7 0.16 290)', ctaStyle: 'violet' },
  { id: 'x402', name: 'x402 · Pay-per-call', price: 'USDC', sub: 'On Base · no signup, no key',
    bullets: ['scan_funding_arb — $0.01/call', 'get_trade_call — $0.02/call', 'get_market_regime — $0.02/call', 'HOLD trade calls — free', '100 free calls/mo first, then pay-per-call'],
    cta: "Pay per call with your agent's wallet →", href: '/docs.html#x402', stripe: 'oklch(0.78 0.13 240)', ctaStyle: 'azure' }];


  const ctaForStyle = (s) => {
    if (s === 'mint-strong') return { background: 'var(--accent, var(--mint))', color: 'oklch(0.16 0.05 165)', boxShadow: '0 8px 24px -8px oklch(0.86 0.16 165 / 0.55)' };
    if (s === 'mint') return { background: 'oklch(0.4 0.1 170 / 0.4)', color: 'var(--accent, var(--mint))', border: '1px solid oklch(0.5 0.12 170 / 0.55)' };
    if (s === 'violet') return { background: 'var(--violet)', color: 'oklch(0.18 0.04 290)' };
    if (s === 'azure') return { background: 'oklch(0.42 0.16 240 / 0.4)', color: 'oklch(0.86 0.13 240)', border: '1px solid oklch(0.5 0.14 240 / 0.55)' };
    return { background: 'oklch(0.22 0.012 265 / 0.7)', color: 'var(--fg)', border: '1px solid var(--line-2)' };
  };

  return (
    <LRBlock id="pricing" mobile={mobile} dim>
      <LREyebrow>· pricing</LREyebrow>
      <LRH2 mobile={mobile}>Simple pricing.</LRH2>
      <p style={{ fontSize: mobile ? 15 : 17, color: 'var(--fg-2)', maxWidth: 700,
        margin: mobile ? '14px 0 18px' : '20px 0 24px', lineHeight: 1.6 }}>
        Start free. Pay when you need more.
      </p>
      <a href="/track-record?from=pricing" style={{ display: 'inline-block', fontSize: mobile ? 12.5 : 13, color: 'var(--accent, var(--mint))', textDecoration: 'none', fontFamily: 'var(--font-mono)', margin: mobile ? '0 0 14px' : '0 0 18px' }}>
        Verify our track record →
      </a>

      <div style={{
        padding: mobile ? '14px 16px' : '16px 22px', marginBottom: mobile ? 24 : 36,
        border: '1px solid oklch(0.5 0.14 165 / 0.45)', borderRadius: 12,
        background: 'linear-gradient(90deg, oklch(0.32 0.08 170 / 0.25), oklch(0.18 0.014 265 / 0.55))',
        display: 'flex', alignItems: 'flex-start', gap: 14, maxWidth: 920
      }}>
        <div style={{ fontFamily: 'var(--font-display)', fontSize: mobile ? 19 : 22, fontWeight: 600, color: 'var(--accent, var(--mint))', lineHeight: 1.1, flexShrink: 0 }}>
          98.8%
        </div>
        <div style={{ fontSize: mobile ? 12.5 : 13.5, color: 'var(--fg-2)', lineHeight: 1.5 }}>
          <span style={{ color: 'var(--fg)', fontWeight: 500 }}>HOLD rate — we only fire when we mean it.</span> Most signal tools always emit a verdict.<br/>We reject 98.8% of scans as HOLD — and HOLDs are always free.<br/>That selectivity is why we have 90.2%+ Merkle-verified accuracy on 80,059+ signals.
        </div>
      </div>

      <div style={{
        display: 'grid',
        gridTemplateColumns: mobile ? '1fr' : 'repeat(5, 1fr)',
        gap: mobile ? 14 : 12,
        alignItems: 'stretch'
      }}>
        {tiers.map((t) =>
        <article key={t.id} style={{
          position: 'relative',
          padding: mobile ? '20px 18px' : '22px 18px 22px',
          border: t.popular ? '1px solid var(--accent, var(--mint))' : '1px solid var(--line)',
          borderRadius: 14,
          background: t.popular ?
          'linear-gradient(180deg, oklch(0.3 0.08 170 / 0.22), oklch(0.18 0.014 265 / 0.6))' :
          'oklch(0.18 0.014 265 / 0.55)',
          boxShadow: t.popular ? '0 0 0 1px oklch(0.86 0.16 165 / 0.12), 0 22px 50px -22px oklch(0.86 0.16 165 / 0.5)' : 'none',
          display: 'flex', flexDirection: 'column', gap: 14,
          transform: !mobile && t.popular ? 'translateY(-8px)' : 'none'
        }}>
            <div style={{ position: 'absolute', top: 0, left: 0, right: 0, height: 2, background: t.stripe, opacity: 0.85 }} />
            {t.popular &&
          <div style={{ position: 'absolute', top: -11, left: 18, padding: '3px 10px', borderRadius: 999,
            background: 'var(--accent, var(--mint))', color: 'oklch(0.16 0.05 165)',
            fontFamily: 'var(--font-mono)', fontSize: 9.5, fontWeight: 700, letterSpacing: '0.16em' }}>
                POPULAR
              </div>
          }
            <div>
              <div style={{ fontFamily: 'var(--font-mono)', fontSize: 11, color: 'var(--fg-3)', letterSpacing: '0.16em', marginBottom: 8 }}>
                {t.name}
              </div>
              <div style={{ display: 'flex', alignItems: 'baseline', gap: 4 }}>
                <span style={{ fontFamily: 'var(--font-display)', fontSize: mobile ? 28 : 30, fontWeight: 600, letterSpacing: '-0.018em', color: 'var(--fg)' }}>
                  {t.price}
                </span>
                {t.period && <span style={{ fontSize: 13, color: 'var(--fg-3)' }}>{t.period}</span>}
              </div>
              <div style={{ fontSize: 12, color: 'var(--fg-3)', marginTop: 5 }}>{t.sub}</div>
            </div>
            <ul style={{ listStyle: 'none', padding: 0, margin: 0, display: 'flex', flexDirection: 'column', gap: 7 }}>
              {t.bullets.map((b, j) => <Bullet key={j} mobile={mobile}>{b}</Bullet>)}
            </ul>
            <div style={{ marginTop: 'auto', display: 'flex', flexDirection: 'column', gap: 8 }}>
              <a href={t.href || `#${t.id}`} style={{
              display: 'inline-flex', justifyContent: 'center', alignItems: 'center',
              padding: '10px 14px', borderRadius: 9,
              fontFamily: 'var(--font-text)', fontSize: 13, fontWeight: 500,
              textDecoration: 'none', textAlign: 'center',
              ...ctaForStyle(t.ctaStyle)
            }}>
                {t.cta}
              </a>
              {t.meta &&
            <a href="https://t.me/algovaultofficialbot" target="_blank" rel="noopener noreferrer" style={{ fontSize: 11.5, textDecoration: 'none', textAlign: 'center', color: "rgb(0, 136, 204)" }}>
                  {t.meta}
                </a>
            }
            </div>
          </article>
        )}
      </div>
    </LRBlock>);

}

