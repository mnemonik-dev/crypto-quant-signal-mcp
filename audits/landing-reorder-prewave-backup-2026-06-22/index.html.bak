-radius:14px;background:oklch(0.18 0.014 265 / 0.55);display:flex;flex-direction:column;gap:14px;min-height:auto"><div style="width:42px;height:42px;border-radius:11px;border:1px solid var(--line-2);background:oklch(0.22 0.012 265 / 0.7);display:grid;place-items:center;color:var(--fg)"><svg width="22" height="22" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 11h18"></path><path d="M19 7l4 4-4 4"></path><path d="M27 21H9" stroke="var(--accent, oklch(0.86 0.16 165))"></path><path d="M13 25l-4-4 4-4" stroke="var(--accent, oklch(0.86 0.16 165))"></path></svg></div><div><div style="font-family:var(--font-display);font-size:19px;font-weight:500;letter-spacing:-0.012em;margin-bottom:6px;color:var(--fg)">Cross-venue funding arbitrage.</div><div style="color:var(--fg-2);font-size:14px;line-height:1.55">Top spreads across Hyperliquid, Binance, Bybit.</div></div><div style="margin-top:auto;padding-top:4px"><span style="display:inline-flex;align-items:center;gap:6px;padding:6px 11px;border:1px solid var(--line);border-radius:999px;background:oklch(0.13 0.012 265 / 0.7);font-family:var(--font-mono);font-size:11.5px;color:var(--accent, var(--mint))"><span style="color:var(--fg-4)">›</span>scan_funding_arb</span></div></article><article style="position:relative;padding:22px 20px;border:1px solid var(--line);border-radius:14px;background:oklch(0.18 0.014 265 / 0.55);display:flex;flex-direction:column;gap:14px;min-height:auto"><div style="width:42px;height:42px;border-radius:11px;border:1px solid var(--line-2);background:oklch(0.22 0.012 265 / 0.7);display:grid;place-items:center;color:var(--fg)"><svg width="22" height="22" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 23 L10 17 L14 20 L20 12 L26 16"></path><circle cx="20" cy="12" r="1.6" fill="var(--accent, oklch(0.86 0.16 165))" stroke="none"></circle><path d="M26 9 a 5 5 0 1 1 -0.01 0" stroke="var(--accent, oklch(0.86 0.16 165))"></path><path d="M26 5 v 3" stroke="var(--accent, oklch(0.86 0.16 165))"></path></svg></div><div><div style="font-family:var(--font-display);font-size:19px;font-weight:500;letter-spacing:-0.012em;margin-bottom:6px;color:var(--fg)">Self-tuning ML model.</div><div style="color:var(--fg-2);font-size:14px;line-height:1.55">Gets sharper with every call.</div></div><div style="margin-top:auto;padding-top:4px"><a href="/how-it-works" style="display:inline-flex;align-items:center;gap:6px;padding:6px 11px;border:1px solid var(--line);border-radius:999px;background:oklch(0.13 0.012 265 / 0.7);font-family:var(--font-mono);font-size:11.5px;color:var(--accent, var(--mint));text-decoration:none"><span style="color:var(--fg-4)">›</span>How it works</a></div></article></div></section><section style="position:relative;padding:64px 22px;border-top:1px solid var(--line);background:linear-gradient(180deg, transparent, oklch(0.155 0.012 265 / 0.7) 30%, oklch(0.155 0.012 265 / 0.7) 70%, transparent)"><div style="display:inline-flex;align-items:center;gap:10px;margin-bottom:18px;font-family:var(--font-mono);font-size:11px;color:var(--fg-3);letter-spacing:0.14em;text-transform:uppercase"><span style="width:5px;height:5px;border-radius:50%;background:var(--accent, var(--mint));box-shadow:0 0 8px var(--accent, var(--mint))"></span>· fit</div><h2 style="font-family:var(--font-display);font-size:30px;line-height:1.05;letter-spacing:-0.022em;font-weight:500;margin:0;text-wrap:balance;color:var(--fg)">When to use AlgoVault</h2><div style="display:grid;grid-template-columns:1fr;gap:14px;margin-top:32px"><article style="position:relative;padding:24px 22px;border:1px solid var(--line);border-radius:14px;background:oklch(0.18 0.014 265 / 0.55);min-height:auto;display:flex;flex-direction:column"><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px"><span style="font-family:var(--font-mono);font-size:11px;color:var(--accent, var(--mint));letter-spacing:0.16em">0<!-- -->1</span><div style="width:38px;height:38px;border-radius:10px;border:1px solid var(--line-2);background:oklch(0.22 0.012 265 / 0.7);display:grid;place-items:center;color:var(--fg)"><svg width="22" height="22" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="11" width="20" height="14" rx="3"></rect><circle cx="12" cy="18" r="1.6" fill="var(--accent, oklch(0.86 0.16 165))" stroke="none"></circle><circle cx="20" cy="18" r="1.6" fill="var(--accent, oklch(0.86 0.16 165))" stroke="none"></circle><path d="M16 6v5"></path><circle cx="16" cy="5" r="1.4" fill="currentColor" stroke="none"></circle><path d="M11 25l-1 4M21 25l1 4"></path></svg></div></div><p style="font-family:var(--font-display);font-size:17px;line-height:1.32;letter-spacing:-0.012em;font-weight:500;margin:0;color:var(--fg);text-wrap:balance">Building an AI agent that trades crypto perps across multiple venues.</p></article><article style="position:relative;padding:24px 22px;border:1px solid var(--line);border-radius:14px;background:oklch(0.18 0.014 265 / 0.55);min-height:auto;display:flex;flex-direction:column"><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px"><span style="font-family:var(--font-mono);font-size:11px;color:var(--accent, var(--mint));letter-spacing:0.16em">0<!-- -->2</span><div style="width:38px;height:38px;border-radius:10px;border:1px solid var(--line-2);background:oklch(0.22 0.012 265 / 0.7);display:grid;place-items:center;color:var(--fg)"><svg width="22" height="22" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"><path d="M16 4 L28 10 L16 16 L4 10 Z" stroke="var(--accent, oklch(0.86 0.16 165))"></path><path d="M4 16 L16 22 L28 16"></path><path d="M4 22 L16 28 L28 22" opacity="0.6"></path></svg></div></div><p style="font-family:var(--font-display);font-size:17px;line-height:1.32;letter-spacing:-0.012em;font-weight:500;margin:0;color:var(--fg);text-wrap:balance">Skipping 8-indicator parsing for one composite verdict per call.</p></article><article style="position:relative;padding:24px 22px;border:1px solid var(--line);border-radius:14px;background:oklch(0.18 0.014 265 / 0.55);min-height:auto;display:flex;flex-direction:column"><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px"><span style="font-family:var(--font-mono);font-size:11px;color:var(--accent, var(--mint));letter-spacing:0.16em">0<!-- -->3</span><div style="width:38px;height:38px;border-radius:10px;border:1px solid var(--line-2);background:oklch(0.22 0.012 265 / 0.7);display:grid;place-items:center;color:var(--fg)"><svg width="22" height="22" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round"><path d="M16 4 L26 8 V17 C26 22 22 26 16 28 C10 26 6 22 6 17 V8 Z"></path><path d="M11 16l4 4 7-8" stroke="var(--accent, oklch(0.86 0.16 165))" stroke-width="2"></path></svg></div></div><p style="font-family:var(--font-display);font-size:17px;line-height:1.32;letter-spacing:-0.012em;font-weight:500;margin:0;color:var(--fg);text-wrap:balance">Verifying signal performance on-chain before integrating.</p></article></div></section><section style="position:relative;padding:64px 22px;border-top:1px solid var(--line);background:transparent"><div style="display:inline-flex;align-items:center;gap:10px;margin-bottom:18px;font-family:var(--font-mono);font-size:11px;color:var(--fg-3);letter-spacing:0.14em;text-transform:uppercase"><span style="width:5px;height:5px;border-radius:50%;background:var(--accent, var(--mint));box-shadow:0 0 8px var(--accent, var(--mint))"></span>· compare</div><h2 style="font-family:var(--font-display);font-size:30px;line-height:1.05;letter-spacing:-0.022em;font-weight:500;margin:0;text-wrap:balance;color:var(--fg)">Why not just use exchange APIs?</h2><p style="font-size:14.5px;color:var(--fg-2);max-width:320px;margin:14px 0 28px;line-height:1.55">Three places to source signal for an agent. Only one is built for verdicts.</p><div style="display:flex;flex-direction:column;gap:12px"><article style="padding:22px 20px;border:1px solid var(--line);border-radius:14px;background:oklch(0.18 0.014 265 / 0.5);box-shadow:none"><div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:14px;gap:12px"><span style="font-family:var(--font-display);font-size:19px;font-weight:500;letter-spacing:-0.012em;color:var(--fg)">Exchange APIs</span><span class="placeholder-cap" style="font-size:9.5px;text-align:right">Raw venue endpoints</span></div><div style="padding-top:10px;border-top:1px solid var(--line)"><div class="placeholder-cap" style="font-size:9.5px;margin-bottom:4px">Output per call</div><div style="font-size:13.5px;color:var(--fg-2);line-height:1.5;margin-bottom:12px;font-weight:400">8 raw indicators per call</div></div><div style="padding-top:10px;border-top:1px solid var(--line)"><div class="placeholder-cap" style="font-size:9.5px;margin-bottom:4px">Built for</div><div style="font-size:13.5px;color:var(--fg-2);line-height:1.5;margin-bottom:12px;font-weight:400">Programmatic raw data — your agent interprets each indicator</div></div><div style="padding-top:10px;border-top:1px solid var(--line)"><div class="placeholder-cap" style="font-size:9.5px;margin-bottom:4px">Integration</div><div style="font-size:13.5px;color:var(--fg-2);line-height:1.5;margin-bottom:12px;font-weight:400">N adapter integrations · per-venue auth · per-venue ratelimits</div></div></article><article style="padding:22px 20px;border:1px solid var(--accent, var(--mint));border-radius:14px;background:linear-gradient(180deg, oklch(0.32 0.08 170 / 0.28), oklch(0.18 0.014 265 / 0.6));box-shadow:0 0 0 1px oklch(0.86 0.16 165 / 0.12), 0 18px 40px -22px oklch(0.86 0.16 165 / 0.4)"><div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:14px;gap:12px"><span style="font-family:var(--font-display);font-size:19px;font-weight:500;letter-spacing:-0.012em;color:var(--accent, var(--mint))">AlgoVault</span><span class="placeholder-cap" style="font-size:9.5px;text-align:right">MCP brain layer</span></div><div style="padding-top:10px;border-top:1px solid var(--line)"><div class="placeholder-cap" style="font-size:9.5px;margin-bottom:4px">Output per call</div><div style="font-size:13.5px;color:var(--fg);line-height:1.5;margin-bottom:12px;font-weight:500">One verdict per call · {call, confidence, regime, factors}</div></div><div style="padding-top:10px;border-top:1px solid var(--line)"><div class="placeholder-cap" style="font-size:9.5px;margin-bottom:4px">Built for</div><div style="font-size:13.5px;color:var(--fg);line-height:1.5;margin-bottom:12px;font-weight:500">AI agents reading verdicts</div></div><div style="padding-top:10px;border-top:1px solid var(--line)"><div class="placeholder-cap" style="font-size:9.5px;margin-bottom:4px">Integration</div><div style="font-size:13.5px;color:var(--fg);line-height:1.5;margin-bottom:12px;font-weight:500">5 venues unified behind one MCP · skip N adapter integrations</div></div></article><article style="padding:22px 20px;border:1px solid var(--line);border-radius:14px;background:oklch(0.18 0.014 265 / 0.5);box-shadow:none"><div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:14px;gap:12px"><span style="font-family:var(--font-display);font-size:19px;font-weight:500;letter-spacing:-0.012em;color:var(--fg)">TradingView · Coinglass</span><span class="placeholder-cap" style="font-size:9.5px;text-align:right">Visual analytics</span></div><div style="padding-top:10px;border-top:1px solid var(--line)"><div class="placeholder-cap" style="font-size:9.5px;margin-bottom:4px">Output per call</div><div style="font-size:13.5px;color:var(--fg-2);line-height:1.5;margin-bottom:12px;font-weight:400">Charts + tables for humans</div></div><div style="padding-top:10px;border-top:1px solid var(--line)"><div class="placeholder-cap" style="font-size:9.5px;margin-bottom:4px">Built for</div><div style="font-size:13.5px;color:var(--fg-2);line-height:1.5;margin-bottom:12px;font-weight:400">Humans reading charts</div></div><div style="padding-top:10px;border-top:1px solid var(--line)"><div class="placeholder-cap" style="font-size:9.5px;margin-bottom:4px">Integration</div><div style="font-size:13.5px;color:var(--fg-2);line-height:1.5;margin-bottom:12px;font-weight:400">Web/app dashboards · screenshot in, decision out</div></div></article></div><p style="margin-top:22px;font-size:13px;color:var(--fg-3)">See <a href="/skills" style="color:var(--accent, var(--mint));text-decoration:none">/skills</a> <!-- -->+ <a href="/docs" style="color:var(--accent, var(--mint));text-decoration:none">/docs</a>.</p></section></div>

<!-- DESIGN-W6 / C3+C4 (2026-05-10, fix-forward ROUND 3 2026-05-11): landing-rest. -->
<div class="lp-rest-desktop"><section id="quickstart" style="position:relative;padding:120px 80px;border-top:1px solid var(--line);background:transparent"><div style="display:inline-flex;align-items:center;gap:10px;margin-bottom:18px;font-family:var(--font-mono);font-size:11px;color:var(--fg-3);letter-spacing:0.14em;text-transform:uppercase"><span style="width:5px;height:5px;border-radius:50%;background:var(--accent, var(--mint));box-shadow:0 0 8px var(--accent, var(--mint))"></span>· quickstart</div><h2 style="font-family:var(--font-display);font-size:48px;line-height:1.05;letter-spacing:-0.022em;font-weight:500;margin:0;text-wrap:balance;color:var(--fg)">Try it in 30 seconds.</h2><p style="font-size:17px;color:var(--fg-2);max-width:720px;margin:20px 0 56px;line-height:1.6">Three steps from idle Claude to live verdict. No SDK, no auth handshake, no cold-start.</p><div style="display:grid;grid-template-columns:repeat(3, 1fr);gap:20px;margin-bottom:44px"><article style="position:relative;padding:32px 30px;border:1px solid var(--line);border-radius:14px;background:oklch(0.18 0.014 265 / 0.55);display:flex;flex-direction:column;gap:14px"><div style="display:flex;align-items:center;justify-content:space-between"><div style="width:36px;height:36px;border-radius:999px;background:oklch(0.22 0.012 265);border:1px solid var(--accent, var(--mint));display:grid;place-items:center;font-family:var(--font-mono);font-size:13px;font-weight:600;color:var(--accent, var(--mint));box-shadow:0 0 14px oklch(0.86 0.16 165 / 0.25)">0<!-- -->1</div></div><div><div style="font-family:var(--font-display);font-size:19px;font-weight:500;color:var(--fg);letter-spacing:-0.012em;margin-bottom:8px;text-wrap:balance">Open Claude → Settings → Integrations</div><div style="font-size:13.5px;color:var(--fg-2);font-family:var(--font-text);line-height:1.55;word-break:normal">Or any MCP-compatible client: Cursor, Windsurf, VS Code, etc.</div></div></article><article style="position:relative;padding:32px 30px;border:1px solid var(--line);border-radius:14px;background:oklch(0.18 0.014 265 / 0.55);display:flex;flex-direction:column;gap:14px"><div style="display:flex;align-items:center;justify-content:space-between"><div style="width:36px;height:36px;border-radius:999px;background:oklch(0.22 0.012 265);border:1px solid var(--accent, var(--mint));display:grid;place-items:center;font-family:var(--font-mono);font-size:13px;font-weight:600;color:var(--accent, var(--mint));box-shadow:0 0 14px oklch(0.86 0.16 165 / 0.25)">0<!-- -->2</div><button style="border:1px solid var(--line-2);background:oklch(0.22 0.012 265 / 0.6);color:var(--fg-2);cursor:pointer;padding:5px 10px;border-radius:7px;font-family:var(--font-mono);font-size:10.5px;letter-spacing:0.08em">COPY</button></div><div><div style="font-family:var(--font-display);font-size:19px;font-weight:500;color:var(--fg);letter-spacing:-0.012em;margin-bottom:8px;text-wrap:balance">Add custom integration → paste the URL</div><div style="font-size:13.5px;color:var(--accent, var(--mint));font-family:var(--font-mono);line-height:1.55;word-break:break-all">https://api.algovault.com/mcp</div></div></article><article style="position:relative;padding:32px 30px;border:1px solid var(--line);border-radius:14px;background:oklch(0.18 0.014 265 / 0.55);display:flex;flex-direction:column;gap:14px"><div style="display:flex;align-items:center;justify-content:space-between"><div style="width:36px;height:36px;border-radius:999px;background:oklch(0.22 0.012 265);border:1px solid var(--accent, var(--mint));display:grid;place-items:center;font-family:var(--font-mono);font-size:13px;font-weight:600;color:var(--accent, var(--mint));box-shadow:0 0 14px oklch(0.86 0.16 165 / 0.25)">0<!-- -->3</div></div><div><div style="font-family:var(--font-display);font-size:19px;font-weight:500;color:var(--fg);letter-spacing:-0.012em;margin-bottom:8px;text-wrap:balance">Ask Claude</div><div style="font-size:13.5px;color:var(--fg-2);font-family:var(--font-text);line-height:1.55;word-break:normal">&quot;Get me a trade call for BTC on the 15m timeframe&quot;</div></div><div style="font-size:11.5px;color:var(--fg-3);border-top:1px solid var(--line);padding-top:12px;margin-top:auto">Free tier: all assets, all <span data-tr-field="timeframe_count">11</span> timeframes, 100 calls/month</div></article></div><div class="code-window" style="font-size:13px"><div class="code-window-header"><span class="code-dot" style="background:#ff5f57"></span><span class="code-dot" style="background:#febc2e"></span><span class="code-dot" style="background:#28c840"></span><span style="margin-left:12px">get_trade_call(<span class="tk-str">&quot;BTC&quot;</span>, <span class="tk-str">&quot;15m&quot;</span>) → response</span><span style="margin-left:auto;color:var(--accent, var(--mint));font-family:var(--font-mono);font-size:10.5px">● 312ms · 200 OK</span></div><div class="code-body" style="padding:20px 24px"><div class="code-line" style="display:flex;gap:60px;opacity:1"><div style="flex:1"><span class="tk-pun">{</span></div><div style="flex:1"></div></div><div class="code-line" style="display:flex;gap:60px;opacity:1"><div style="flex:1"><span>  </span><span class="tk-key">&quot;asset&quot;</span><span class="tk-pun">:</span><span> </span><span class="tk-str">&quot;BTC&quot;</span><span class="tk-pun">,</span></div><div style="flex:1"><span>  </span><span class="tk-key">&quot;timeframe&quot;</span><span class="tk-pun">:</span><span> </span><span class="tk-str">&quot;15m&quot;</span><span class="tk-pun">,</span></div></div><div class="code-line" style="display:flex;gap:60px;opacity:1"><div style="flex:1"><span>  </span><span class="tk-key">&quot;call&quot;</span><span class="tk-pun">:</span><span> </span><span class="tk-str">&quot;BUY&quot;</span><span class="tk-pun">,</span></div><div style="flex:1"><span>  </span><span class="tk-key">&quot;confidence&quot;</span><span class="tk-pun">:</span><span> </span><span class="tk-num">0.74</span><span class="tk-pun">,</span></div></div><div class="code-line" style="display:flex;gap:60px;opacity:1"><div style="flex:1"><span>  </span><span class="tk-key">&quot;regime&quot;</span><span class="tk-pun">:</span><span> </span><span class="tk-str">&quot;trending_up&quot;</span><span class="tk-pun">,</span></div><div style="flex:1"><span>  </span><span class="tk-key">&quot;factors&quot;</span><span class="tk-pun">:</span><span> </span><span class="tk-pun">{</span></div></div><div class="code-line" style="display:flex;gap:60px;opacity:1"><div style="flex:1"><span>    </span><span class="tk-key">&quot;trend_persistence&quot;</span><span class="tk-pun">:</span><span> </span><span class="tk-str">&quot;HIGH&quot;</span><span class="tk-pun">,</span></div><div style="flex:1"><span>    </span><span class="tk-key">&quot;funding_state&quot;</span><span class="tk-pun">:</span><span> </span><span class="tk-str">&quot;NEUTRAL&quot;</span><span class="tk-pun">,</span></div></div><div class="code-line" style="display:flex;gap:60px;opacity:1"><div style="flex:1"><span>    </span><span class="tk-key">&quot;breakout_pending&quot;</span><span class="tk-pun">:</span><span> </span><span class="tk-str">&quot;ACTIVE&quot;</span><span class="tk-pun">,</span></div><div style="flex:1"><span>    </span><span class="tk-key">&quot;volatility_regime&quot;</span><span class="tk-pun">:</span><span> </span><span class="tk-str">&quot;normal&quot;</span><span class="tk-pun">,</span></div></div><div class="code-line" style="display:flex;gap:60px;opacity:1"><div style="flex:1"><span>  </span><span class="tk-pun">}</span><span class="tk-pun">,</span></div><div style="flex:1"><span>  </span><span class="tk-key">&quot;merkle_id&quot;</span><span class="tk-pun">:</span><span> </span><span class="tk-str">&quot;0x4a2…f91&quot;</span></div></div><div class="code-line" style="display:flex;gap:60px;opacity:1"><div style="flex:1"><span class="tk-pun">}</span></div><div style="flex:1"></div></div></div></div></section><section id="three-tools" style="position:relative;padding:120px 80px;border-top:1px solid var(--line);background:linear-gradient(180deg, transparent, oklch(0.155 0.012 265 / 0.7) 30%, oklch(0.155 0.012 265 / 0.7) 70%, transparent)"><div style="display:inline-flex;align-items:center;gap:10px;margin-bottom:18px;font-family:var(--font-mono);font-size:11px;color:var(--fg-3);letter-spacing:0.14em;text-transform:uppercase"><span style="width:5px;height:5px;border-radius:50%;background:var(--accent, var(--mint));box-shadow:0 0 8px var(--accent, var(--mint))"></span>· tools</div><h2 style="font-family:var(--font-display);font-size:48px;line-height:1.05;letter-spacing:-0.022em;font-weight:500;margin:0;text-wrap:balance;color:var(--fg)">3 tools, One verdict.</h2><p style="font-size:17px;color:var(--fg-2);max-width:720px;margin:20px 0 56px;line-height:1.6">Each tool combines multiple data sources into a single, actionable answer.<br/>Assets are classified into quality tiers with institutional-grade liquidity filtering.</p><div style="display:grid;grid-template-columns:repeat(3, 1fr);gap:20px"><article style="padding:28px 28px 24px;border:1px solid var(--line);border-radius:14px;background:oklch(0.18 0.014 265 / 0.55);display:flex;flex-direction:column;gap:18px"><span style="display:inline-flex;align-items:center;gap:6px;padding:6px 11px;border-radius:999px;border:1px solid var(--line);background:oklch(0.13 0.012 265 / 0.7);font-family:var(--font-mono);font-size:11.5px;color:var(--accent, var(--mint));align-self:flex-start"><span style="color:var(--fg-4)">›</span>get_trade_call</span><div style="font-family:var(--font-display);font-size:22px;font-weight:500;letter-spacing:-0.014em;color:var(--fg)">Composite Trade Call</div><ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:8px"><li style="display:flex;gap:10px;align-items:flex-start;font-size:14.5px;color:var(--fg-2);line-height:1.5"><svg width="14" height="14" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:3px"><path d="M3 8.5l3.2 3L13 4.5" stroke="var(--accent, var(--mint))" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Multi-factor composite scoring</span></li><li style="display:flex;gap:10px;align-items:flex-start;font-size:14.5px;color:var(--fg-2);line-height:1.5"><svg width="14" height="14" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:3px"><path d="M3 8.5l3.2 3L13 4.5" stroke="var(--accent, var(--mint))" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Regime-aware filtering</span></li><li style="display:flex;gap:10px;align-items:flex-start;font-size:14.5px;color:var(--fg-2);line-height:1.5"><svg width="14" height="14" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:3px"><path d="M3 8.5l3.2 3L13 4.5" stroke="var(--accent, var(--mint))" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Crypto + TradFi</span></li><li style="display:flex;gap:10px;align-items:flex-start;font-size:14.5px;color:var(--fg-2);line-height:1.5"><svg width="14" height="14" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:3px"><path d="M3 8.5l3.2 3L13 4.5" stroke="var(--accent, var(--mint))" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg><span><span data-tr-field="timeframe_count">11</span> timeframes (1m–1d)</span></li></ul><div style="margin-top:auto;padding:14px 14px;border-radius:10px;border:1px solid var(--line);background:oklch(0.13 0.01 265);font-family:var(--font-mono);font-size:11.5px;line-height:1.5;color:var(--fg-2);word-break:break-word">→ <span style="color:var(--green)">BUY 68%</span> · trend_persistence: <span style="color:oklch(0.82 0.12 65)">HIGH</span> · funding_state: <span style="color:oklch(0.82 0.12 65)">ELEVATED</span> · breakout_pending: <span style="color:var(--fg-3)">INACTIVE</span></div></article><article style="padding:28px 28px 24px;border:1px solid var(--line);border-radius:14px;background:oklch(0.18 0.014 265 / 0.55);display:flex;flex-direction:column;gap:18px"><span style="display:inline-flex;align-items:center;gap:6px;padding:6px 11px;border-radius:999px;border:1px solid var(--line);background:oklch(0.13 0.012 265 / 0.7);font-family:var(--font-mono);font-size:11.5px;color:var(--accent, var(--mint));align-self:flex-start"><span style="color:var(--fg-4)">›</span>scan_funding_arb</span><div style="font-family:var(--font-display);font-size:22px;font-weight:500;letter-spacing:-0.014em;color:var(--fg)">Funding Rate Arbitrage</div><ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:8px"><li style="display:flex;gap:10px;align-items:flex-start;font-size:14.5px;color:var(--fg-2);line-height:1.5"><svg width="14" height="14" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:3px"><path d="M3 8.5l3.2 3L13 4.5" stroke="var(--accent, var(--mint))" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Hyperliquid vs Binance vs Bybit</span></li><li style="display:flex;gap:10px;align-items:flex-start;font-size:14.5px;color:var(--fg-2);line-height:1.5"><svg width="14" height="14" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:3px"><path d="M3 8.5l3.2 3L13 4.5" stroke="var(--accent, var(--mint))" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Normalized hourly rates</span></li><li style="display:flex;gap:10px;align-items:flex-start;font-size:14.5px;color:var(--fg-2);line-height:1.5"><svg width="14" height="14" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:3px"><path d="M3 8.5l3.2 3L13 4.5" stroke="var(--accent, var(--mint))" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Annualized spreads in basis points</span></li><li style="display:flex;gap:10px;align-items:flex-start;font-size:14.5px;color:var(--fg-2);line-height:1.5"><svg width="14" height="14" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:3px"><path d="M3 8.5l3.2 3L13 4.5" stroke="var(--accent, var(--mint))" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Ranked by opportunity size</span></li></ul><div style="margin-top:auto;padding:14px 14px;border-radius:10px;border:1px solid var(--line);background:oklch(0.13 0.01 265);font-family:var(--font-mono);font-size:11.5px;line-height:1.5;color:var(--fg-2);word-break:break-word">→ <span style="color:var(--accent, var(--mint))">DOGE +42 bps</span> spread · HL <span style="color:oklch(0.82 0.12 65)">+0.83%</span> vs Binance <span style="color:var(--fg-3)">+0.01%</span></div></article><article style="padding:28px 28px 24px;border:1px solid var(--line);border-radius:14px;background:oklch(0.18 0.014 265 / 0.55);display:flex;flex-direction:column;gap:18px"><span style="display:inline-flex;align-items:center;gap:6px;padding:6px 11px;border-radius:999px;border:1px solid var(--line);background:oklch(0.13 0.012 265 / 0.7);font-family:var(--font-mono);font-size:11.5px;color:var(--accent, var(--mint));align-self:flex-start"><span style="color:var(--fg-4)">›</span>get_market_regime</span><div style="font-family:var(--font-display);font-size:22px;font-weight:500;letter-spacing:-0.014em;color:var(--fg)">Market Regime Detection</div><ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:8px"><li style="display:flex;gap:10px;align-items:flex-start;font-size:14.5px;color:var(--fg-2);line-height:1.5"><svg width="14" height="14" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:3px"><path d="M3 8.5l3.2 3L13 4.5" stroke="var(--accent, var(--mint))" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Trending / Ranging / Volatile</span></li><li style="display:flex;gap:10px;align-items:flex-start;font-size:14.5px;color:var(--fg-2);line-height:1.5"><svg width="14" height="14" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:3px"><path d="M3 8.5l3.2 3L13 4.5" stroke="var(--accent, var(--mint))" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Multi-dimensional classification</span></li><li style="display:flex;gap:10px;align-items:flex-start;font-size:14.5px;color:var(--fg-2);line-height:1.5"><svg width="14" height="14" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:3px"><path d="M3 8.5l3.2 3L13 4.5" stroke="var(--accent, var(--mint))" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Cross-venue funding sentiment</span></li><li style="display:flex;gap:10px;align-items:flex-start;font-size:14.5px;color:var(--fg-2);line-height:1.5"><svg width="14" height="14" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:3px"><path d="M3 8.5l3.2 3L13 4.5" stroke="var(--accent, var(--mint))" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Strategy &amp; sizing suggestions</span></li></ul><div style="margin-top:auto;padding:14px 14px;border-radius:10px;border:1px solid var(--line);background:oklch(0.13 0.01 265);font-family:var(--font-mono);font-size:11.5px;line-height:1.5;color:var(--fg-2);word-break:break-word">→ <span style="color:var(--green)">TRENDING_UP</span> ADX=<span style="color:oklch(0.82 0.12 65)">34.2</span> · Funding sentiment: <span style="color:var(--accent, var(--mint))">BULLISH_BIAS</span></div></article></div></section><section id="use-cases" style="position:relative;padding:120px 80px;border-top:1px solid var(--line);background:transparent"><div style="display:inline-flex;align-items:center;gap:10px;margin-bottom:18px;font-family:var(--font-mono);font-size:11px;color:var(--fg-3);letter-spacing:0.14em;text-transform:uppercase"><span style="width:5px;height:5px;border-radius:50%;background:var(--accent, var(--mint));box-shadow:0 0 8px var(--accent, var(--mint))"></span>· use cases</div><h2 style="font-family:var(--font-display);font-size:48px;line-height:1.05;letter-spacing:-0.022em;font-weight:500;margin:0;text-wrap:balance;color:var(--fg)">Brain + execution pairing.</h2><p style="font-size:17px;color:var(--fg-2);max-width:780px;margin:20px 0 56px;line-height:1.6">AlgoVault MCP gives your agent a composite verdict in one call.<br/>Pair it with any of these official Agent Trade Kits to ship a complete trading agent.</p><div style="display:grid;grid-template-columns:repeat(4, 1fr);gap:16px"><article style="position:relative;padding:24px 22px 22px;border:1px solid var(--line);border-radius:14px;background:oklch(0.18 0.014 265 / 0.55);display:flex;flex-direction:column;gap:14px;overflow:hidden"><div style="position:absolute;top:0;left:0;right:0;height:2px;background:oklch(0.82 0.16 85);opacity:0.85"></div><div style="display:flex;align-items:center;gap:10px"><span class="xchg-mark" style="width:32px;height:32px;border-radius:7px;background:var(--bg-2);border:1px solid var(--line);display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0"><img src="/_design/logos/binance.png" alt="Binance logo" style="width:26px;height:26px;object-fit:contain"></span><div style="display:flex;flex-direction:column"><span style="font-family:var(--font-display);font-size:18px;font-weight:500;letter-spacing:-0.012em;color:var(--fg)">Binance<!-- --> × AlgoVault</span><span style="font-family:var(--font-mono);font-size:10px;color:var(--fg-4);letter-spacing:0.06em">official Skills Hub</span></div></div><p style="margin:0;font-size:14px;color:var(--fg-2);line-height:1.5">Composite verdict + official Binance Skills Hub for Spot Testnet execution</p><div style="margin-top:auto;display:flex;flex-direction:column;gap:10px;padding-top:12px;border-top:1px solid var(--line)"><span style="font-family:var(--font-mono);font-size:11px;color:var(--fg-3);word-break:break-all;line-height:1.4">binance/binance-skills-hub</span><a href="#tutorial" style="font-family:var(--font-text);font-size:13px;color:var(--accent, var(--mint));text-decoration:none;display:inline-flex;align-items:center;gap:5px">View tutorial <span style="font-family:var(--font-mono)">→</span></a></div></article><article style="position:relative;padding:24px 22px 22px;border:1px solid var(--line);border-radius:14px;background:oklch(0.18 0.014 265 / 0.55);display:flex;flex-direction:column;gap:14px;overflow:hidden"><div style="position:absolute;top:0;left:0;right:0;height:2px;background:oklch(0.82 0.005 265);opacity:0.85"></div><div style="display:flex;align-items:center;gap:10px"><span class="xchg-mark" style="width:32px;height:32px;border-radius:7px;background:var(--bg-2);border:1px solid var(--line);display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0"><img src="/_design/logos/okx.png" alt="OKX logo" style="width:26px;height:26px;object-fit:contain"></span><div style="display:flex;flex-direction:column"><span style="font-family:var(--font-display);font-size:18px;font-weight:500;letter-spacing:-0.012em;color:var(--fg)">OKX<!-- --> × AlgoVault</span><span style="font-family:var(--font-mono);font-size:10px;color:var(--fg-4);letter-spacing:0.06em">83 tools</span></div></div><p style="margin:0;font-size:14px;color:var(--fg-2);line-height:1.5">Composite verdict + 83 OKX execution tools across spot, swap, futures, options, grid bots</p><div style="margin-top:auto;display:flex;flex-direction:column;gap:10px;padding-top:12px;border-top:1px solid var(--line)"><span style="font-family:var(--font-mono);font-size:11px;color:var(--fg-3);word-break:break-all;line-height:1.4">@okx_ai/okx-trade-mcp@1.3.1</span><a href="#tutorial" style="font-family:var(--font-text);font-size:13px;color:var(--accent, var(--mint));text-decoration:none;display:inline-flex;align-items:center;gap:5px">View tutorial <span style="font-family:var(--font-mono)">→</span></a></div></article><article style="position:relative;padding:24px 22px 22px;border:1px solid var(--line);border-radius:14px;backg