<!-- LANDING-LIVE-CALL-TICKER-W1: ticker polling + count-up animation. Polls
     /api/performance-public (totalCalls + totalHolds) and /api/recent-calls?limit=1
     in parallel every 3s. Independent 1s tick updates seconds_ago. Graceful
     fetch-failure handling — keeps last-known values; never blanks the UI. -->
<script>
(function(){
  'use strict';
  var PERF_URL = '/api/performance-public';
  var RECENT_URL = '/api/recent-calls?limit=1';
  var POLL_MS = 3000;
  var TICK_MS = 1000;
  var COUNT_ANIM_MS = 200;

  var $count = document.getElementById('ticker-count');
  var $last = document.getElementById('ticker-last');
  if (!$count || !$last) return;

  var displayed = null;          // currently rendered count (number)
  var lastCall = null;           // {slug, exchange, timeframe, call, seconds_ago, created_at_iso}
  var lastFetchMs = 0;           // wall-clock of most recent successful /api/recent-calls

  function fmt(n) { return n.toLocaleString('en-US'); }

  function animateCountTo(target) {
    if (displayed === null || target === displayed) {
      displayed = target;
      $count.textContent = fmt(target);
      return;
    }
    var start = displayed;
    var delta = target - start;
    var t0 = performance.now();
    function step(now) {
      var p = Math.min(1, (now - t0) / COUNT_ANIM_MS);
      // ease-out cubic
      var eased = 1 - Math.pow(1 - p, 3);
      var v = Math.round(start + delta * eased);
      $count.textContent = fmt(v);
      if (p < 1) requestAnimationFrame(step);
      else { displayed = target; $count.textContent = fmt(target); }
    }
    requestAnimationFrame(step);
  }

  function paintLastCall() {
    if (!lastCall) { $last.textContent = 'Last call · —'; return; }
    var elapsedSec = lastCall.seconds_ago;
    if (lastFetchMs) {
      // Tick locally: wall-clock delta since the last successful fetch.
      elapsedSec = lastCall.seconds_ago + Math.floor((Date.now() - lastFetchMs) / 1000);
    }
    var ago = elapsedSec < 60
      ? elapsedSec + 's ago'
      : Math.floor(elapsedSec / 60) + 'm ' + (elapsedSec % 60) + 's ago';
    $last.textContent = lastCall.slug + ' · ' + lastCall.timeframe + ' · ' +
      lastCall.exchange + ' · ' + lastCall.call + ' · ' + ago;
  }

  function refresh() {
    Promise.all([
      fetch(PERF_URL, { cache: 'no-store' }).then(function(r){ return r.ok ? r.json() : null; }).catch(function(){ return null; }),
      fetch(RECENT_URL, { cache: 'no-store' }).then(function(r){ return r.ok ? r.json() : null; }).catch(function(){ return null; })
    ]).then(function(results){
      var perf = results[0];
      var recent = results[1];
      if (perf && typeof perf.totalCalls === 'number' && typeof perf.totalHolds === 'number') {
        animateCountTo(perf.totalCalls + perf.totalHolds);
      }
      if (Array.isArray(recent) && recent.length > 0 && recent[0] && typeof recent[0].slug === 'string') {
        lastCall = recent[0];
        lastFetchMs = Date.now();
        paintLastCall();
      }
    }).catch(function(err){
      // Keep last-known UI; log for diagnostics.
      // eslint-disable-next-line no-console
      console.warn('[live-call-ticker] refresh failed', err);
    });
  }

  // First paint: immediate fetch on DOMContentLoaded (or now, if already past).
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', refresh);
  } else {
    refresh();
  }
  setInterval(refresh, POLL_MS);
  setInterval(paintLastCall, TICK_MS);
})();
</script>

<!-- DESIGN-W3 / C3: recent-calls feed poller. Vanilla JS, no React.
     Hydrates #recent-calls-rows from /api/recent-calls?limit=5 every 2500ms.
     Same data shape as the live-call-ticker (sanitized public shape per
     audits/recent-calls-public-shape-snapshot-2026-05-09.json) but a separate
     poller — different rendering target (5-row feed vs 1-row last-call line). -->
<script>
(function() {
  var FEED_LIMIT = 5;
  var POLL_MS = 2500;
  var rowsEl = document.getElementById('recent-calls-rows');
  if (!rowsEl) return;

  function fmtTimeAgo(seconds) {
    if (seconds == null || !isFinite(seconds) || seconds < 0) return '—';
    if (seconds < 60) return seconds.toFixed(1) + 's ago';
    if (seconds < 3600) return Math.round(seconds / 60) + 'm ago';
    return Math.round(seconds / 3600) + 'h ago';
  }

  function callClass(call) {
    var c = (call || '').toUpperCase();
    if (c === 'BUY') return 'recent-calls-call recent-calls-call-buy';
    if (c === 'SELL') return 'recent-calls-call recent-calls-call-sell';
    return 'recent-calls-call recent-calls-call-hold';
  }

  function escapeHtml(s) {
    return String(s == null ? '' : s).replace(/[&<>"']/g, function(c) {
      return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] || c;
    });
  }

  function renderRows(rows) {
    if (!Array.isArray(rows) || rows.length === 0) {
      rowsEl.innerHTML = '<div class="recent-calls-empty">No recent calls.</div>';
      return;
    }
    var html = rows.slice(0, FEED_LIMIT).map(function(r) {
      var coin = escapeHtml(r.slug);
      var tf = escapeHtml(r.timeframe);
      var call = escapeHtml((r.call || '').toUpperCase());
      var time = escapeHtml(fmtTimeAgo(r.seconds_ago));
      return '<div class="recent-calls-row">' +
        '<span class="recent-calls-coin">' + coin + '</span>' +
        '<span class="recent-calls-tf">' + tf + '</span>' +
        '<span class="' + callClass(r.call) + '">' + call + '</span>' +
        '<span class="recent-calls-time">' + time + '</span>' +
        '</div>';
    }).join('');
    rowsEl.innerHTML = html;
  }

  function fetchRecentCalls() {
    fetch('/api/recent-calls?limit=' + FEED_LIMIT)
      .then(function(r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      })
      .then(renderRows)
      .catch(function(err) {
        // On error: keep last-known rows; log to console for ops debugging.
        console.warn('[recent-calls-feed] refresh failed', err);
      });
  }

  fetchRecentCalls();
  setInterval(fetchRecentCalls, 2500); // POLL_MS — keep literal so verification gate matches
})();
</script>

</body>
</html>
