                </div>
              </div>
              <div>
                <div className="placeholder-cap" style={{ fontSize: 10 }}>signals</div>
                <div style={{ fontFamily: 'var(--font-mono)', fontSize: 15, color: 'var(--fg)', marginTop: 2 }}>
                  37
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>);

}

window.V1Hero = V1Hero;